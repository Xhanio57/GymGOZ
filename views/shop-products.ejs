<script>
let products = [];
let categoriesList = [];
let currentCat = 'all';
let activeProduct = null;
let selectedSize = null;
let cart = [];
let selectedFilters = {
  brands: [],
  sizes: [],
  priceMin: 0,
  priceMax: 10000
};
let currentPage = 1;
const itemsPerPage = 12;
let currentSort = 'featured';

const heroMap = {
  all:      { img: 'https://images.unsplash.com/photo-1517838277536-f5f99be501cd?q=80&w=1200&auto=format&fit=crop', title: 'Tüm <span>Ürünler</span>' },
  'spor-giyim':    { img: 'https://images.unsplash.com/photo-1501555088652-021faa106b9b?q=80&w=1200&auto=format&fit=crop', title: 'Outdoor <span>Giyim</span>' },
  'cocuk-giyim':    { img: 'https://images.unsplash.com/photo-1501555088652-021faa106b9b?q=80&w=1200&auto=format&fit=crop', title: 'Çocuk <span>Giyim</span>' },
  'judogi':    { img: 'https://images.unsplash.com/photo-1509198397868-475647b2a1e5?q=80&w=1200&auto=format&fit=crop', title: 'Branş <span>Ürünleri</span>' },
  'kamp-malzemeleri':     { img: 'https://images.unsplash.com/photo-1504280390367-361c6d9f38f4?q=80&w=1200&auto=format&fit=crop', title: 'Kamp <span>Ekipmanları</span>' },
  'aksesuarlar': { img: 'https://images.unsplash.com/photo-1553062407-98eeb64c6a62?q=80&w=1200&auto=format&fit=crop', title: '<span>Aksesuarlar</span>' }
};

function catLabel(c) {
  return c;
}

function toggleMobileMenu() {
  const nav = document.getElementById('navLinks');
  nav.classList.toggle('active');
}

function toggleSidebar(open) {
  const sidebar = document.getElementById('product-sidebar');
  const overlay = document.getElementById('sidebar-overlay');
  if (!sidebar || !overlay) return;
  if (open) {
    sidebar.classList.add('open');
    overlay.classList.add('open');
    document.body.style.overflow = 'hidden';
  } else {
    sidebar.classList.remove('open');
    overlay.classList.remove('open');
    document.body.style.overflow = '';
  }
}

/* =====================
   INITIALIZE FILTERS
===================== */
function initializeFilters() {
  // const brandsSet = new Set();
  // products.forEach(p => {
  //   if (p.brand) brandsSet.add(p.brand);
  // });
  //
  // const brands = Array.from(brandsSet).sort();
  // const brandContainer = document.getElementById('brand-filters');
  // brandContainer.innerHTML = '';
  // brands.forEach(brand => {
  //   const label = document.createElement('label');
  //   label.className = 'brand-item';
  //   label.innerHTML = `<input type="checkbox" value="${brand}" onchange="applyFilters()"><label>${brand}</label>`;
  //   brandContainer.appendChild(label);
  // });
}

function renderSidebarCategories() {
  const container = document.getElementById('categories-sidebar');
  if (!container) return;

  let html = `
    <div class="sidebar-item active" data-cat="all" onclick="filterCat(this, 'all', 'Tüm Ürünler')">
      Tüm Ürünler <span class="count" id="count-all">${products.length}</span>
    </div>
  `;

  categoriesList.forEach(cat => {
    const catCount = products.filter(p => p.cat === cat.name).length;
    const subHtml = (cat.subcategories || []).map(sub => {
      const subCount = products.filter(p => p.subcat === sub.slug).length;
      return `
        <div class="sidebar-sub-item" onclick="filterSub(event, '${sub.slug}', '${sub.name}')">
          ${sub.name} <span style="font-size:10px; color:var(--gray-400)">(${subCount})</span>
        </div>
      `;
    }).join('');

    html += `
      <div class="sidebar-item" data-cat="${cat.name}" onclick="filterCat(this, '${cat.name}', '${cat.name}')">
        ${cat.name} <span class="count" id="count-${cat._id}">${catCount}</span>
      </div>
      ${cat.subcategories && cat.subcategories.length > 0 ? `
        <div class="sidebar-sub" id="sub-${cat._id}" style="display:none">
          ${subHtml}
        </div>
      ` : ''}
    `;
  });

  container.innerHTML = html;

  // Build nav dropdown dynamically too
  const dropdown = document.getElementById('nav-categories-dropdown');
  if (dropdown) {
    dropdown.innerHTML = categoriesList.map(cat => `
      <a onclick="filterByNav('${cat.name}')"><span class="dot"></span>${cat.name}</a>
    `).join('');
  }
}

/* =====================
   RENDER PRODUCTS
===================== */
function renderProducts(items) {
  const grid = document.getElementById('product-grid');
  document.getElementById('results-count').textContent = items.length + ' ürün listeleniyor';

  if (!items.length) {
    grid.innerHTML = '<div class="empty-state"><h3>Ürün Bulunamadı</h3><p>Farklı filtreler deneyin.</p></div>';
    renderPagination([]);
    return;
  }

  const startIndex = (currentPage - 1) * itemsPerPage;
  const endIndex = startIndex + itemsPerPage;
  const pageItems = items.slice(startIndex, endIndex);

  grid.innerHTML = pageItems.map(p => `
    <div class="product-card" onclick="openPopup('${p.id}')">
      ${p.badge ? `<div class="badge ${p.badge === 'YENİ' ? 'yeni' : ''}">${p.badge}</div>` : ''}
      <div class="product-img-wrap">
        <img src="${p.img}" alt="${p.name}" loading="lazy" onerror="this.src='/images/default-product.png'">
      </div>
      <div class="product-info">
        <div class="product-cat">${catLabel(p.cat)}</div>
        <div class="product-name">${p.name}</div>
        <div class="product-desc">${p.desc}</div>
        <div class="product-footer">
          <span class="product-price">${p.price.toLocaleString('tr-TR')} TL</span>
          <button class="btn-detail" onclick="openPopup('${p.id}'); event.stopPropagation();">İncele</button>
        </div>
      </div>
    </div>
  `).join('');

  renderPagination(items);
}

/* =====================
   PAGINATION
===================== */
function renderPagination(items) {
  const container = document.getElementById('pagination-container');
  const totalPages = Math.ceil(items.length / itemsPerPage);
  
  if (totalPages <= 1) {
    container.innerHTML = '';
    return;
  }

  let html = '';
  
  if (currentPage > 1) {
    html += `<button class="page-btn" onclick="goToPage(${currentPage - 1})">←</button>`;
  }

  for (let i = 1; i <= totalPages; i++) {
    html += `<button class="page-btn ${i === currentPage ? 'active' : ''}" onclick="goToPage(${i})">${i}</button>`;
  }

  if (currentPage < totalPages) {
    html += `<button class="page-btn" onclick="goToPage(${currentPage + 1})">→</button>`;
  }

  container.innerHTML = html;
}

function goToPage(page) {
  currentPage = page;
  const items = getFilteredSortedProducts();
  renderProducts(items);
  window.scrollTo({ top: document.getElementById('product-grid').offsetTop - 100, behavior: 'smooth' });
}

/* =====================
   FILTERING & SORTING
 ===================== */
function getFilteredSortedProducts() {
  selectedFilters.brands = Array.from(document.querySelectorAll('#brand-filters input:checked')).map(el => el.value);
  selectedFilters.sizes = Array.from(document.querySelectorAll('#size-filters input:checked')).map(el => el.value);
  selectedFilters.priceMin = parseInt(document.getElementById('priceMin').value) || 0;
  selectedFilters.priceMax = parseInt(document.getElementById('priceMax').value) || 10000;

  const searchTerm = document.getElementById('searchInput').value.toLowerCase();

  let items = [...products];

  if (currentCat !== 'all') {
    items = items.filter(p => p.cat === currentCat || p.subcat === currentCat);
  }

  if (selectedFilters.brands.length > 0) {
    items = items.filter(p => selectedFilters.brands.includes(p.brand));
  }

  if (selectedFilters.sizes.length > 0) {
    items = items.filter(p => p.sizes.some(size => selectedFilters.sizes.some(selected => size.includes(selected) || selected.includes(size))));
  }

  items = items.filter(p => p.price >= selectedFilters.priceMin && p.price <= selectedFilters.priceMax);

  if (searchTerm) {
    items = items.filter(p => p.name.toLowerCase().includes(searchTerm) || p.desc.toLowerCase().includes(searchTerm));
  }

  // Apply sorting
  if (currentSort === 'featured') {
    items.sort((a, b) => {
      const aInStock = (a.totalStock || 0) > 0;
      const bInStock = (b.totalStock || 0) > 0;
      if (aInStock && !bInStock) return -1;
      if (!aInStock && bInStock) return 1;
      
      const aScore = (a.views || 0) * 10 + (a.totalStock || 0);
      const bScore = (b.views || 0) * 10 + (b.totalStock || 0);
      return bScore - aScore;
    });
  } else if (currentSort === 'price-asc') {
    items.sort((a, b) => a.price - b.price);
  } else if (currentSort === 'price-desc') {
    items.sort((a, b) => b.price - a.price);
  } else if (currentSort === 'newest') {
    items.sort((a, b) => (b.id < a.id ? -1 : 1));
  }

  return items;
}

function applyFilters() {
  currentPage = 1;
  updateActiveFilters();
  const items = getFilteredSortedProducts();
  renderProducts(items);
  toggleSidebar(false);
}

function updateActiveFilters() {
  const container = document.getElementById('active-filters');
  const tags = [];

  if (selectedFilters.brands.length > 0) {
    selectedFilters.brands.forEach(brand => {
      tags.push(`<div class="filter-tag">${brand} <span class="x" onclick="removeBrandFilter('${brand}')">×</span></div>`);
    });
  }

  if (selectedFilters.sizes.length > 0) {
    selectedFilters.sizes.forEach(size => {
      tags.push(`<div class="filter-tag">Beden: ${size} <span class="x" onclick="removeSizeFilter('${size}')">×</span></div>`);
    });
  }

  container.innerHTML = tags.join('');
}

function removeBrandFilter(brand) {
  const checkbox = Array.from(document.querySelectorAll('#brand-filters input')).find(el => el.value === brand);
  if (checkbox) checkbox.checked = false;
  applyFilters();
}

function removeSizeFilter(size) {
  const checkboxes = Array.from(document.querySelectorAll('#size-filters input'));
  checkboxes.forEach(el => {
    if (el.value === size || size.includes(el.value)) el.checked = false;
  });
  applyFilters();
}

function filterCat(el, cat, label) {
  currentCat = cat;
  currentPage = 1;
  document.querySelectorAll('.sidebar-item').forEach(i => i.classList.remove('active'));
  el.classList.add('active');
  document.querySelectorAll('.sidebar-sub').forEach(s => s.style.display = 'none');
  
  // Clear size filter section and hide it since we selected a main category
  document.getElementById('size-filter-section').style.display = 'none';
  selectedFilters.sizes = [];
  document.querySelectorAll('#size-filters input').forEach(cb => cb.checked = false);

  if (cat !== 'all') {
    const category = categoriesList.find(c => c.name === cat);
    if (category) {
      const sub = document.getElementById('sub-' + category._id);
      if (sub) sub.style.display = 'block';
    }
  }

  document.getElementById('breadcrumb-current').textContent = label;
  
  // Set hero image/title
  const slug = cat.toLowerCase().replace(/[^a-z0-9]+/g, '-');
  const h = heroMap[slug] || heroMap.all;
  document.getElementById('hero-img').src = h.img;
  document.getElementById('hero-title').innerHTML = cat === 'all' ? 'Tüm <span>Ürünler</span>' : `${cat}`;

  applyFilters();
}

function filterSub(e, subcat, label) {
  e.stopPropagation();
  document.querySelectorAll('.sidebar-sub-item').forEach(i => i.classList.remove('active'));
  e.target.classList.add('active');
  currentCat = subcat;
  currentPage = 1;
  document.getElementById('breadcrumb-current').textContent = label;

  // Show sizes filter for the parent category of this subcategory
  const parentCat = categoriesList.find(cat => (cat.subcategories || []).some(sub => sub.slug === subcat));
  if (parentCat && parentCat.sizes && parentCat.sizes.length > 0 && parentCat.sizes[0] !== 'Tek Boyut') {
    const sizeContainer = document.getElementById('size-filters');
    sizeContainer.innerHTML = parentCat.sizes.map(size => `
      <label class="brand-item">
        <input type="checkbox" value="${size}" onchange="applyFilters()">
        <label>${size}</label>
      </label>
    `).join('');
    document.getElementById('size-filter-section').style.display = 'block';
  } else {
    document.getElementById('size-filter-section').style.display = 'none';
    selectedFilters.sizes = [];
    document.querySelectorAll('#size-filters input').forEach(cb => cb.checked = false);
  }

  applyFilters();
}

function filterByNav(categoryName) {
  const el = document.querySelector(`.sidebar-item[data-cat="${categoryName}"]`);
  if (el) filterCat(el, categoryName, categoryName);
  toggleMobileMenu();
}

// Keep other functions intact
function sortProducts(val) {
  currentSort = val;
  applyFilters();
}

/* =====================
   POPUP LOGIC
===================== */
function updateWhatsAppLink(sizeName) {
  if (!activeProduct) return;
  let msg = `${activeProduct.name} bu ürün için sipariş oluşturmak istiyorum`;
  if (sizeName && sizeName !== 'Tek Boyut') {
    msg = `${activeProduct.name} (Beden: ${sizeName}) bu ürün için sipariş oluşturmak istiyorum`;
  }
  const url = `https://wa.me/905078707550?text=${encodeURIComponent(msg)}`;
  document.getElementById('popup-shopier-link').href = url;
}

function setStockStatus(inStock) {
  const stockEl = document.getElementById('popup-stock');
  const shopierLink = document.getElementById('popup-shopier-link');
  
  if (inStock) {
    stockEl.textContent = 'Stokta Var';
    stockEl.style.color = '#2d8c40';
    stockEl.className = 'popup-stock in-stock';
    shopierLink.classList.remove('disabled');
    shopierLink.innerHTML = 'WhatsApp ile Sipariş Ver <span class="arrow">→</span>';
  } else {
    stockEl.textContent = 'Tükendi';
    stockEl.style.color = '#dc2626';
    stockEl.className = 'popup-stock out-of-stock-status';
    shopierLink.classList.add('disabled');
    shopierLink.innerHTML = 'TÜKENDİ <span class="arrow">→</span>';
  }
}

function openPopup(id) {
  const p = products.find(x => x.id === id);
  if (!p) return;

  activeProduct = p;

  p.views = (p.views || 0) + 1;
  fetch('/api/products/' + id + '/view', { method: 'POST' }).catch(err => console.error('Error recording view:', err));

  document.getElementById('popup-img').src = p.img;
  document.getElementById('popup-cat').textContent = catLabel(p.cat);
  document.getElementById('popup-name').textContent = p.name;
  document.getElementById('popup-desc-main').textContent = p.longDesc;
  document.getElementById('popup-price').textContent = p.price.toLocaleString('tr-TR') + ' TL';

  const badgeEl = document.getElementById('popup-badge');
  if (p.badge) {
    badgeEl.textContent = p.badge;
    badgeEl.className = 'popup-badge' + (p.badge === 'YENİ' ? ' yeni' : '');
    badgeEl.style.display = 'block';
  } else {
    badgeEl.style.display = 'none';
  }

  document.getElementById('popup-features').innerHTML = p.features.map(f => `<li>${f}</li>`).join('');

  const sizeStockList = p.sizeStock || [];
  let selectedIndex = -1;
  let defaultSize = 'Tek Boyut';

  if (sizeStockList.length > 0) {
    document.getElementById('popup-sizes').innerHTML = sizeStockList.map((item, idx) => {
      const isOutOfStock = (item.stock || 0) <= 0;
      let isSelectedClass = '';
      if (!isOutOfStock && selectedIndex === -1) {
        selectedIndex = idx;
        isSelectedClass = 'selected';
      }
      return `<div class="size-btn ${isSelectedClass} ${isOutOfStock ? 'out-of-stock' : ''}" 
                   onclick="selectSize(this, '${item.size}', ${item.stock || 0})">${item.size}</div>`;
    }).join('');

    if (selectedIndex === -1) {
      const firstBtn = document.querySelector('#popup-sizes .size-btn');
      if (firstBtn) firstBtn.classList.add('selected');
      setStockStatus(false);
      defaultSize = sizeStockList[0].size;
    } else {
      setStockStatus(true);
      defaultSize = sizeStockList[selectedIndex].size;
    }
  } else {
    const isOutOfStock = !p.stock;
    document.getElementById('popup-sizes').innerHTML = `<div class="size-btn selected ${isOutOfStock ? 'out-of-stock' : ''}" 
                 onclick="selectSize(this, 'Tek Boyut', ${isOutOfStock ? 0 : 10})">Tek Boyut</div>`;
    setStockStatus(!isOutOfStock);
  }

  selectedSize = defaultSize;
  updateWhatsAppLink(defaultSize);

  document.getElementById('popup-overlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function selectSize(el, sizeName, stockCount) {
  if (el.classList.contains('out-of-stock')) return;
  
  document.querySelectorAll('.size-btn').forEach(b => b.classList.remove('selected'));
  el.classList.add('selected');
  
  selectedSize = sizeName;
  setStockStatus(stockCount > 0);
  updateWhatsAppLink(sizeName);
}

// Popup event listeners
function closePopup(e) {
  if (e.target === document.getElementById('popup-overlay')) closePopupDirect();
}

function closePopupDirect() {
  document.getElementById('popup-overlay').classList.remove('open');
  document.body.style.overflow = '';
}

document.addEventListener('keydown', e => { if (e.key === 'Escape') closePopupDirect(); });

/* =====================
   DYNAMIC DB LOADING
===================== */
async function loadProducts() {
  try {
    const catRes = await fetch('/api/categories');
    categoriesList = await catRes.json();

    const res = await fetch('/api/products');
    const dbProducts = await res.json();
    
    const inStockDbProducts = dbProducts.filter(p => {
      const sizeStock = Array.isArray(p.sizeStock) ? p.sizeStock : [];
      const totalStock = sizeStock.reduce((total, item) => total + (item.stock || 0), 0);
      return totalStock > 0;
    });
    
    products = inStockDbProducts.map(p => {
      const sizeStock = Array.isArray(p.sizeStock) ? p.sizeStock : [];
      const totalStock = sizeStock.reduce((total, item) => total + (item.stock || 0), 0);
      
      let finalPrice = p.price;
      if (p.discountType === 'percentage' && p.discountValue > 0) {
        finalPrice = p.price * (1 - p.discountValue / 100);
      } else if (p.discountType === 'fixed' && p.discountValue > 0) {
        finalPrice = Math.max(0, p.price - p.discountValue);
      }
      
      return {
        id: p._id,
        cat: p.category,
        subcat: p.subcat || '',
        brand: p.brand || 'Öz Spor',
        name: p.name,
        desc: p.description ? (p.description.length > 70 ? p.description.substring(0, 67) + '...' : p.description) : '',
        longDesc: p.description || '',
        features: Array.isArray(p.features) ? p.features : [],
        sizes: sizeStock.length > 0 ? sizeStock.map(s => s.size) : ['Tek Boyut'],
        sizeStock: sizeStock,
        price: finalPrice,
        badge: p.badge || '',
        stock: totalStock > 0,
        totalStock: totalStock,
        views: p.views || 0,
        img: p.image || '/images/default-product.png',
        link: p.shopierLink || 'https://www.shopier.com/oz_spor_outdoor'
      };
    });
    
    renderSidebarCategories();
    initializeFilters();

    const selectedCat = localStorage.getItem('selectedCategory');
    if (selectedCat && selectedCat !== 'null') {
      const catElement = document.querySelector(`.sidebar-item[data-cat="${selectedCat}"]`);
      if (catElement) {
        filterCat(catElement, selectedCat, selectedCat);
      }
      localStorage.removeItem('selectedCategory');
    } else {
      applyFilters();
    }

    // Load cart from localStorage
    loadCart();
  } catch (err) {
    console.error('Ürünler yüklenirken hata oluştu:', err);
    document.getElementById('product-grid').innerHTML = '<div class="empty-state"><h3>Hata Oluştu</h3><p>Ürünler veri tabanından yüklenemedi.</p></div>';
  }
}

/* =====================
   CART MANAGEMENT
===================== */
function loadCart() {
  const savedCart = localStorage.getItem('gymgoz_cart');
  if (savedCart) {
    try {
      cart = JSON.parse(savedCart);
    } catch (e) {
      cart = [];
    }
  }
  updateCartUI();
}

function saveCart() {
  localStorage.setItem('gymgoz_cart', JSON.stringify(cart));
  updateCartUI();
}

function toggleCart(show) {
  const drawer = document.getElementById('cartDrawer');
  const backdrop = document.getElementById('cartBackdrop');
  if (!drawer || !backdrop) return;
  if (show) {
    drawer.classList.add('open');
    backdrop.style.display = 'block';
  } else {
    drawer.classList.remove('open');
    backdrop.style.display = 'none';
  }
}

function addToCart(productId, name, size, price, image) {
  if (!size) {
    alert('Lütfen bir beden seçin!');
    return;
  }

  const existingItem = cart.find(item => item.productId === productId && item.size === size);
  if (existingItem) {
    existingItem.quantity += 1;
  } else {
    cart.push({
      productId,
      name,
      size,
      price: parseFloat(price),
      image,
      quantity: 1
    });
  }
  saveCart();
  toggleCart(true);
}

function changeCartQty(productId, size, change) {
  const item = cart.find(item => item.productId === productId && item.size === size);
  if (item) {
    item.quantity += change;
    if (item.quantity <= 0) {
      cart = cart.filter(x => !(x.productId === productId && x.size === size));
    }
    saveCart();
  }
}

function removeFromCart(productId, size) {
  cart = cart.filter(x => !(x.productId === productId && x.size === size));
  saveCart();
}

function updateCartUI() {
  const cartBadge = document.getElementById('cartBadge');
  const cartItemsContainer = document.getElementById('cartItemsContainer');
  const cartTotalAmount = document.getElementById('cartTotalAmount');
  const checkoutBtn = document.getElementById('checkoutBtn');
  
  if (!cartBadge || !cartItemsContainer || !cartTotalAmount || !checkoutBtn) return;

  const totalItems = cart.reduce((total, item) => total + item.quantity, 0);
  cartBadge.textContent = totalItems;
  if (totalItems > 0) {
    cartBadge.style.display = 'flex';
  } else {
    cartBadge.style.display = 'none';
  }

  const totalPrice = cart.reduce((total, item) => total + (item.price * item.quantity), 0);
  cartTotalAmount.textContent = totalPrice.toLocaleString('tr-TR') + ' TL';

  if (cart.length === 0) {
    cartItemsContainer.innerHTML = `
      <div class="cart-empty">
        <div class="cart-empty-icon">🛒</div>
        <div>Sepetiniz Boş</div>
      </div>
    `;
    checkoutBtn.style.pointerEvents = 'none';
    checkoutBtn.style.opacity = '0.5';
  } else {
    checkoutBtn.style.pointerEvents = 'auto';
    checkoutBtn.style.opacity = '1';
    
    cartItemsContainer.innerHTML = cart.map(item => {
      return `
        <div class="cart-item">
          <img src="${item.image}" onerror="this.src='/images/default-product.png'">
          <div class="cart-item-details">
            <div class="cart-item-name">${item.name}</div>
            <div class="cart-item-size">Beden: ${item.size}</div>
            <div class="cart-item-price">${item.price.toLocaleString('tr-TR')} TL</div>
            <div class="cart-item-qty-control">
              <button class="cart-qty-btn" onclick="changeCartQty('${item.productId}', '${item.size}', -1)">-</button>
              <span class="cart-qty-val">${item.quantity}</span>
              <button class="cart-qty-btn" onclick="changeCartQty('${item.productId}', '${item.size}', 1)">+</button>
            </div>
          </div>
          <button class="cart-item-remove" onclick="removeFromCart('${item.productId}', '${item.size}')">Kaldır</button>
        </div>
      `;
    }).join('');
  }
}

function addToCartClick() {
  if (!activeProduct) return;
  if (!selectedSize) {
    alert('Lütfen bir beden seçin!');
    return;
  }
  
  addToCart(activeProduct.id, activeProduct.name, selectedSize, activeProduct.price, activeProduct.img);
  closePopupDirect();
}

window.addEventListener('load', loadProducts);
</script>

