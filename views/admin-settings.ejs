<%- include('layout', { 
  title: 'Ayarlar',
  body: `
  <div class="settings-container">
    <h2>⚙️ Ayarlar (Kategori & Marka Yönetimi)</h2>
    
    <div class="settings-grid">
      <!-- KATEGORİ VE ALT KATEGORİ YÖNETİMİ -->
      <div class="settings-card">
        <h3>📂 Kategori Yönetimi</h3>
        
        <form id="categoryForm" class="settings-form">
          <div class="form-group">
            <label for="newCatName">Yeni Kategori Adı</label>
            <input type="text" id="newCatName" placeholder="Örn: Çocuk Giyim" required>
          </div>
          <div class="form-group">
            <label for="newCatSizes">Beden Listesi (Virgülle ayırın)</label>
            <input type="text" id="newCatSizes" placeholder="Örn: S, M, L VEYA 1 Yaş, 2 Yaş VEYA Tek Boyut">
            <small style="color: #6b7280; font-size: 11px;">Boş bırakılırsa varsayılan olarak 'Tek Boyut' atanır.</small>
          </div>
          <button type="submit" class="btn btn-primary w-100">Kategori Ekle</button>
        </form>

        <hr style="border: 0; border-top: 1px solid #e5e7eb; margin: 20px 0;">

        <h4>Mevcut Kategoriler</h4>
        <div id="categoriesList" class="settings-list">
          <!-- Dinamik olarak doldurulacak -->
        </div>
      </div>

      <!-- MARKA YÖNETİMİ -->
      <div class="settings-card">
        <h3>🏷️ Marka Yönetimi</h3>
        
        <form id="brandForm" class="settings-form">
          <div class="form-group">
            <label for="newBrandName">Yeni Marka Adı</label>
            <input type="text" id="newBrandName" placeholder="Örn: Adidas" required>
          </div>
          <button type="submit" class="btn btn-primary w-100">Marka Ekle</button>
        </form>

        <hr style="border: 0; border-top: 1px solid #e5e7eb; margin: 20px 0;">

        <h4>Mevcut Markalar</h4>
        <div id="brandsList" class="settings-list">
          <!-- Dinamik olarak doldurulacak -->
        </div>
      </div>
    </div>
  </div>

  <style>
    .settings-container {
      background: var(--adm-surface, #141418);
      padding: 30px;
      border-radius: 8px;
      color: var(--adm-text, #f0f0ec);
    }
    .settings-container h2 {
      margin-bottom: 25px;
      color: var(--adm-accent, #d4ff00);
      font-family: 'Bebas Neue', sans-serif;
      letter-spacing: 2px;
      font-size: 32px;
    }
    .settings-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 30px;
    }
    .settings-card {
      background: var(--adm-surface2, #1c1c22);
      border: 1px solid var(--adm-border, #2a2a32);
      border-radius: 8px;
      padding: 20px;
      color: var(--adm-text, #f0f0ec);
    }
    .settings-card h3 {
      margin-top: 0;
      color: var(--adm-accent, #d4ff00);
      margin-bottom: 15px;
      border-bottom: 2px solid var(--adm-border, #2a2a32);
      padding-bottom: 8px;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 20px;
      letter-spacing: 1px;
    }
    .settings-card h4 {
      color: var(--adm-text, #f0f0ec);
      margin-bottom: 12px;
    }
    .settings-form {
      margin-bottom: 15px;
    }
    .form-group {
      margin-bottom: 12px;
    }
    .form-group label {
      display: block;
      font-weight: 600;
      margin-bottom: 6px;
      color: var(--adm-muted, #888884);
      font-size: 13px;
    }
    .form-group input {
      width: 100%;
      padding: 8px 12px;
      border: 1px solid var(--adm-border, #2a2a32);
      border-radius: 6px;
      font-size: 14px;
      box-sizing: border-box;
      background: var(--adm-bg, #0d0d0f);
      color: var(--adm-text, #f0f0ec);
    }
    .w-100 {
      width: 100%;
    }
    .settings-list {
      display: flex;
      flex-direction: column;
      gap: 15px;
    }
    .category-item, .brand-item {
      background: var(--adm-surface, #141418);
      border: 1px solid var(--adm-border, #2a2a32);
      border-radius: 6px;
      padding: 12px;
      color: var(--adm-text, #f0f0ec);
    }
    .item-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 8px;
    }
    .brand-item .item-header {
      margin-bottom: 0;
    }
    .item-title {
      font-weight: bold;
      color: var(--adm-text, #f0f0ec);
      font-size: 15px;
    }
    .btn-delete-small {
      background: var(--adm-danger, #ff4d4d);
      color: white;
      border: none;
      padding: 4px 8px;
      border-radius: 4px;
      font-size: 11px;
      cursor: pointer;
    }
    .btn-delete-small:hover {
      opacity: 0.9;
    }
    .item-details {
      font-size: 12px;
      color: var(--adm-text, #f0f0ec);
      margin-bottom: 8px;
      background: var(--adm-surface2, #1c1c22);
      padding: 6px;
      border-radius: 4px;
      border: 1px solid var(--adm-border, #2a2a32);
    }
    .subcategories-section {
      border-top: 1px dashed var(--adm-border, #2a2a32);
      padding-top: 8px;
      margin-top: 8px;
    }
    .subcategories-list {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-bottom: 8px;
    }
    .subcategory-tag {
      background: var(--adm-surface2, #1c1c22);
      color: var(--adm-text, #f0f0ec);
      padding: 3px 8px;
      border-radius: 4px;
      font-size: 11px;
      font-weight: 500;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      border: 1px solid var(--adm-border, #2a2a32);
    }
    .btn-remove-sub {
      background: none;
      border: none;
      color: var(--adm-danger, #ff4d4d);
      cursor: pointer;
      font-weight: bold;
      padding: 0;
      font-size: 11px;
    }
    .subcategory-add-form {
      display: flex;
      gap: 6px;
    }
    .subcategory-add-form input {
      flex: 1;
      padding: 4px 8px;
      border: 1px solid var(--adm-border, #2a2a32);
      border-radius: 4px;
      font-size: 12px;
      background: var(--adm-bg, #0d0d0f);
      color: var(--adm-text, #f0f0ec);
    }
    .btn-add-sub {
      background: var(--adm-accent, #d4ff00);
      color: #0d0d0f;
      font-weight: 600;
      border: none;
      padding: 4px 8px;
      border-radius: 4px;
      font-size: 12px;
      cursor: pointer;
    }
    .btn-add-sub:hover {
      background: #c8f000;
    }
    @media (max-width: 992px) {
      .settings-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <script>
    async function loadAll() {
      await loadCategories();
      await loadBrands();
    }

    async function loadCategories() {
      try {
        const response = await fetch('/api/categories');
        const categories = await response.json();
        const container = document.getElementById('categoriesList');
        
        container.innerHTML = categories.map(cat => {
          const subRows = (cat.subcategories || []).map(sub => {
            const subSizesVal = (sub.sizes || []).join(', ');
            return '<div style="display:flex; align-items:center; gap:8px; margin-bottom:8px; background:rgba(255,255,255,0.03); padding:6px; border-radius:6px; border:1px solid rgba(255,255,255,0.08);">' +
              '<span style="font-weight:600; font-size:12px; color:var(--adm-text, #333); width:100px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">' + sub.name + '</span>' +
              '<input type="text" id="subSizesInput_' + cat._id + '_' + sub._id + '" value="' + subSizesVal + '" placeholder="Bedenler (örn: S, M, L)" style="flex:1; padding:4px 8px; font-size:11px; border:1px solid var(--adm-border, #cbd5e1); border-radius:4px; box-sizing:border-box; background:rgba(0,0,0,0.2); color:inherit;">' +
              '<button onclick="updateSubcategorySizes(\\\'' + cat._id + '\\\', \\\'' + sub._id + '\\\')" class="btn-add-sub" style="padding:4px 8px; font-size:11px; background:#2563eb; color:white; border-radius:4px; border:none; cursor:pointer;">Güncelle</button>' +
              '<button onclick="deleteSubcategory(\\\'' + cat._id + '\\\', \\\'' + sub._id + '\\\')" class="btn-remove-sub" style="font-size:14px; padding:0 4px; color:#ef4444; border:none; background:none; cursor:pointer;" title="Alt Kategoriyi Sil">×</button>' +
            '</div>';
          }).join('');

          return '<div class="category-item">' +
              '<div class="item-header">' +
                '<span class="item-title">' + cat.name + '</span>' +
                '<button onclick="deleteCategory(\\\'' + cat._id + '\\\')" class="btn-delete-small">🗑️ Sil</button>' +
              '</div>' +
              '<div class="item-details" style="display:flex; align-items:center; gap:8px; margin-bottom:12px; border-bottom:1px dashed var(--adm-border, #cbd5e1); padding-bottom:12px;">' +
                '<strong style="font-size:12px; color:var(--adm-text, #374151); min-width:60px;">Bedenler:</strong>' +
                '<input type="text" id="catSizesInput_' + cat._id + '" value="' + (cat.sizes || []).join(', ') + '" style="flex:1; padding:4px 8px; font-size:11px; border:1px solid var(--adm-border, #cbd5e1); border-radius:4px; background:rgba(0,0,0,0.2); color:inherit;">' +
                '<button onclick="updateCategorySizes(\\\'' + cat._id + '\\\')" class="btn-add-sub" style="padding:4px 8px; font-size:11px; background:#2563eb; color:white; border-radius:4px; border:none; cursor:pointer;">Güncelle</button>' +
              '</div>' +
              '<div class="subcategories-section">' +
                '<div style="font-size: 12px; font-weight: bold; margin-bottom: 8px; color: var(--adm-text, #475569);">Alt Kategoriler:</div>' +
                '<div class="subcategories-list-wrapper" style="margin-bottom:8px;">' +
                  (subRows || '<span style="font-size:11px; color:#94a3b8; font-style:italic; display:block; margin-bottom:8px;">Alt kategori eklenmemiş</span>') +
                '</div>' +
                '<div class="subcategory-add-form" style="display:flex; flex-direction:column; gap:6px; margin-top:10px; border-top:1px dashed var(--adm-border, #cbd5e1); padding-top:10px;">' +
                  '<div style="font-size: 11px; font-weight: bold; color: var(--adm-text, #475569);">Yeni Alt Kategori Ekle:</div>' +
                  '<div style="display:flex; gap:6px;">' +
                    '<input type="text" id="subInput_' + cat._id + '" placeholder="Alt Kategori Adı" required style="flex:1; padding:4px 8px; font-size:12px; border:1px solid var(--adm-border, #cbd5e1); border-radius:4px; background:rgba(0,0,0,0.2); color:inherit;">' +
                    '<input type="text" id="subSizesAdd_' + cat._id + '" placeholder="Bedenler (örn: S,M,L) (opsiyonel)" style="flex:1; padding:4px 8px; font-size:12px; border:1px solid var(--adm-border, #cbd5e1); border-radius:4px; background:rgba(0,0,0,0.2); color:inherit;">' +
                    '<button onclick="addSubcategory(\\\'' + cat._id + '\\\')" class="btn-add-sub" style="padding:4px 10px; font-size:12px; background:#10b981; color:white; border:none; border-radius:4px; cursor:pointer;">Ekle</button>' +
                  '</div>' +
                '</div>' +
              '</div>' +
            '</div>';
        }).join('');
      } catch (err) {
        console.error('Kategoriler yüklenemedi:', err);
      }
    }

    async function loadBrands() {
      try {
        const response = await fetch('/api/brands');
        const brands = await response.json();
        const container = document.getElementById('brandsList');
        
        container.innerHTML = brands.map(brand => {
          const isVisible = brand.isVisible !== false; // default true
          const visibilityBtnText = isVisible ? '👁️ Açık' : '🙈 Gizli';
          const visibilityBtnColor = isVisible ? 'rgba(34,197,94,0.2)' : 'rgba(245,158,11,0.2)';
          const visibilityTxtColor = isVisible ? 'var(--adm-success, #22c55e)' : 'var(--adm-warning, #f59e0b)';
          return '<div class="brand-item">' +
            '<div class="item-header">' +
              '<span class="item-title">' + brand.name + '</span>' +
              '<div style="display:flex; gap:6px;">' +
                '<button onclick="toggleBrandVisibility(\\\'' + brand._id + '\\\', ' + !isVisible + ')" class="btn-add-sub" style="padding:4px 8px; font-size:11px; background:' + visibilityBtnColor + '; color:' + visibilityTxtColor + '; border-radius:4px; font-weight:600; border:1px solid ' + visibilityTxtColor + '; cursor:pointer;">' + visibilityBtnText + '</button>' +
                '<button onclick="deleteBrand(\\\'' + brand._id + '\\\')" class="btn-delete-small">🗑️ Sil</button>' +
              '</div>' +
            '</div>' +
          '</div>';
        }).join('');
      } catch (err) {
        console.error('Markalar yüklenemedi:', err);
      }
    }

    // Category Add
    document.getElementById('categoryForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      const name = document.getElementById('newCatName').value.trim();
      const sizes = document.getElementById('newCatSizes').value.trim();
      
      try {
        const res = await fetch('/api/categories', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, sizes })
        });
        const data = await res.json();
        if (res.ok) {
          document.getElementById('newCatName').value = '';
          document.getElementById('newCatSizes').value = '';
          loadCategories();
        } else {
          alert('Hata: ' + data.message);
        }
      } catch (err) {
        alert('İşlem başarısız');
      }
    });

    // Category Delete
    async function deleteCategory(id) {
      if (!confirm('Bu kategoriyi silmek istediğinize emin misiniz?')) return;
      try {
        const res = await fetch('/api/categories/' + id, { method: 'DELETE' });
        const data = await res.json();
        if (res.ok) {
          loadCategories();
        } else {
          alert('Hata: ' + data.message);
        }
      } catch (err) {
        alert('Silme işlemi başarısız');
      }
    }

    // Category Sizes Update
    async function updateCategorySizes(catId) {
      const input = document.getElementById('catSizesInput_' + catId);
      const sizes = input.value.trim();
      try {
        const res = await fetch('/api/categories/' + catId + '/sizes', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ sizes })
        });
        const data = await res.json();
        if (res.ok) {
          alert('✅ Kategori bedenleri başarıyla güncellendi.');
          loadCategories();
        } else {
          alert('Hata: ' + data.message);
        }
      } catch (err) {
        alert('Güncelleme başarısız');
      }
    }

    // Subcategory Sizes Update
    async function updateSubcategorySizes(catId, subId) {
      const input = document.getElementById('subSizesInput_' + catId + '_' + subId);
      const sizes = input.value.trim();
      try {
        const res = await fetch('/api/categories/' + catId + '/subcategories/' + subId + '/sizes', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ sizes })
        });
        const data = await res.json();
        if (res.ok) {
          alert('✅ Alt kategori bedenleri başarıyla güncellendi.');
          loadCategories();
        } else {
          alert('Hata: ' + data.message);
        }
      } catch (err) {
        alert('Güncelleme başarısız');
      }
    }

    // Subcategory Add
    async function addSubcategory(catId) {
      const input = document.getElementById('subInput_' + catId);
      const sizesInput = document.getElementById('subSizesAdd_' + catId);
      const name = input.value.trim();
      const sizes = sizesInput.value.trim();
      if (!name) {
        alert('Lütfen bir alt kategori adı girin');
        return;
      }
      try {
        const res = await fetch('/api/categories/' + catId + '/subcategories', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, sizes })
        });
        const data = await res.json();
        if (res.ok) {
          input.value = '';
          sizesInput.value = '';
          loadCategories();
        } else {
          alert('Hata: ' + data.message);
        }
      } catch (err) {
        alert('Ekleme işlemi başarısız');
      }
    }

    // Subcategory Delete
    async function deleteSubcategory(catId, subId) {
      if (!confirm('Bu alt kategoriyi silmek istediğinize emin misiniz?')) return;
      try {
        const res = await fetch('/api/categories/' + catId + '/subcategories/' + subId, { method: 'DELETE' });
        const data = await res.json();
        if (res.ok) {
          loadCategories();
        } else {
          alert('Hata: ' + data.message);
        }
      } catch (err) {
        alert('Silme işlemi başarısız');
      }
    }

    // Brand Add
    document.getElementById('brandForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      const name = document.getElementById('newBrandName').value.trim();
      
      try {
        const res = await fetch('/api/brands', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name })
        });
        const data = await res.json();
        if (res.ok) {
          document.getElementById('newBrandName').value = '';
          loadBrands();
        } else {
          alert('Hata: ' + data.message);
        }
      } catch (err) {
        alert('İşlem başarısız');
      }
    });

    // Brand Visibility Toggle
    async function toggleBrandVisibility(id, isVisible) {
      try {
        const res = await fetch('/api/brands/' + id + '/visibility', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ isVisible })
        });
        const data = await res.json();
        if (res.ok) {
          loadBrands();
        } else {
          alert('Hata: ' + data.message);
        }
      } catch (err) {
        alert('İşlem başarısız');
      }
    }

    // Brand Delete
    async function deleteBrand(id) {
      if (!confirm('Bu markayı silmek istediğinize emin misiniz?')) return;
      try {
        const res = await fetch('/api/brands/' + id, { method: 'DELETE' });
        const data = await res.json();
        if (res.ok) {
          loadBrands();
        } else {
          alert('Hata: ' + data.message);
        }
      } catch (err) {
        alert('Silme işlemi başarısız');
      }
    }

    loadAll();
  </script>
  `
}) %>
