<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %> | Öz Spor & Outdoor</title>
<link rel="icon" type="image/png" href="/images/default-product.png">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root { --black: #0a0a0a; --white: #f5f5f0; --accent: #d4ff00; --gray-400: #999990; --gray-600: #555550; }
  body { font-family: 'Barlow', sans-serif; background: var(--black); color: var(--white); min-height: 100vh; display: flex; flex-direction: column; }

  /* Nav */
  .auth-nav { height: 64px; display: flex; align-items: center; justify-content: space-between; padding: 0 28px; border-bottom: 2px solid #1a1a1a; }
  .nav-logo { font-family: 'Bebas Neue', sans-serif; font-size: 22px; letter-spacing: 2px; color: var(--white); text-decoration: none; }
  .nav-logo span { color: var(--accent); }
  .nav-back { color: var(--gray-400); text-decoration: none; font-size: 13px; font-weight: 500; letter-spacing: 1px; transition: color .2s; }
  .nav-back:hover { color: var(--accent); }

  /* Container */
  .auth-wrapper { flex: 1; display: flex; align-items: center; justify-content: center; padding: 40px 20px; }
  .auth-card {
    width: 100%; max-width: 440px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    backdrop-filter: blur(20px);
    border-radius: 16px;
    padding: 40px 32px;
  }

  /* Tabs */
  .auth-tabs { display: flex; gap: 0; margin-bottom: 32px; border-bottom: 2px solid #222; }
  .auth-tab {
    flex: 1; text-align: center; padding: 14px 0; font-size: 13px; font-weight: 700;
    letter-spacing: 2px; text-transform: uppercase; color: var(--gray-400);
    background: none; border: none; cursor: pointer; position: relative;
    transition: color .2s;
  }
  .auth-tab.active { color: var(--accent); }
  .auth-tab.active::after {
    content: ''; position: absolute; bottom: -2px; left: 0; right: 0;
    height: 2px; background: var(--accent);
  }

  /* Form */
  .auth-form { display: none; }
  .auth-form.active { display: block; }
  .form-group { margin-bottom: 18px; }
  .form-group label { display: block; font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--gray-400); margin-bottom: 8px; }
  .form-group input {
    width: 100%; padding: 13px 16px; background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1); border-radius: 8px;
    color: var(--white); font-size: 14px; font-family: 'Barlow', sans-serif;
    transition: border-color .2s;
  }
  .form-group input:focus { outline: none; border-color: var(--accent); }
  .form-group input::placeholder { color: var(--gray-600); }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

  .btn-auth {
    width: 100%; padding: 14px; margin-top: 8px;
    background: var(--accent); color: var(--black);
    font-size: 13px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase;
    border: none; border-radius: 8px; cursor: pointer;
    transition: background .2s, transform .1s;
  }
  .btn-auth:hover { background: #e3ff4d; }
  .btn-auth:active { transform: scale(0.98); }

  /* Messages */
  .msg-error { background: rgba(239,68,68,0.15); border: 1px solid rgba(239,68,68,0.3); color: #fca5a5; padding: 12px 16px; border-radius: 8px; font-size: 13px; margin-bottom: 20px; }
  .msg-success { background: rgba(34,197,94,0.15); border: 1px solid rgba(34,197,94,0.3); color: #86efac; padding: 12px 16px; border-radius: 8px; font-size: 13px; margin-bottom: 20px; }

  .auth-footer { text-align: center; margin-top: 24px; font-size: 12px; color: var(--gray-600); }
  .auth-footer a { color: var(--accent); text-decoration: none; font-weight: 600; }

  @media (max-width: 480px) {
    .auth-card { padding: 32px 20px; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>

<nav class="auth-nav">
  <a href="/" class="nav-logo">Öz Spor <span>&</span> Outdoor</a>
  <a href="/products" class="nav-back">← Alışverişe Dön</a>
</nav>

<div class="auth-wrapper">
  <div class="auth-card">
    <div class="auth-tabs">
      <button class="auth-tab <%= tab === 'login' ? 'active' : '' %>" onclick="switchTab('login')">Giriş Yap</button>
      <button class="auth-tab <%= tab === 'register' ? 'active' : '' %>" onclick="switchTab('register')">Üye Ol</button>
    </div>

    <% if (error) { %>
      <div class="msg-error"><%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="msg-success"><%= success %></div>
    <% } %>

    <!-- LOGIN FORM -->
    <form class="auth-form <%= tab === 'login' ? 'active' : '' %>" id="loginForm" method="POST" action="/account/login">
      <input type="hidden" name="redirect" value="<%= redirect %>">
      <div class="form-group">
        <label>E-posta</label>
        <input type="email" name="email" placeholder="ornek@mail.com" required>
      </div>
      <div class="form-group">
        <label>Şifre</label>
        <input type="password" name="password" placeholder="••••••" required>
        <div style="text-align: right; margin-top: 8px;">
          <a href="#" onclick="switchTab('forgot'); return false;" style="color: var(--accent); font-size: 11px; text-decoration: none; font-weight: 500; letter-spacing: 0.5px;">Şifremi Unuttum</a>
        </div>
      </div>
      <button type="submit" class="btn-auth">Giriş Yap</button>
    </form>

    <!-- REGISTER FORM -->
    <form class="auth-form <%= tab === 'register' ? 'active' : '' %>" id="registerForm" method="POST" action="/account/register">
      <input type="hidden" name="redirect" value="<%= redirect %>">
      <div class="form-row">
        <div class="form-group">
          <label>Ad</label>
          <input type="text" name="firstName" placeholder="Adınız" required>
        </div>
        <div class="form-group">
          <label>Soyad</label>
          <input type="text" name="lastName" placeholder="Soyadınız" required>
        </div>
      </div>
      <div class="form-group">
        <label>E-posta</label>
        <input type="email" name="email" placeholder="ornek@mail.com" required>
      </div>
      <div class="form-group">
        <label>Telefon <span style="color:#555; font-weight:400; text-transform:none; letter-spacing:0;">(isteğe bağlı)</span></label>
        <input type="tel" name="phone" placeholder="05XX XXX XX XX">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Şifre</label>
          <input type="password" name="password" placeholder="Min. 6 karakter" required minlength="6">
        </div>
        <div class="form-group">
          <label>Şifre Tekrar</label>
          <input type="password" name="passwordConfirm" placeholder="••••••" required minlength="6">
        </div>
      </div>
      <button type="submit" class="btn-auth">Üye Ol</button>
    </form>

    <!-- FORGOT PASSWORD FORM -->
    <form class="auth-form <%= tab === 'forgot' ? 'active' : '' %>" id="forgotForm" method="POST" action="/account/forgot-password">
      <input type="hidden" name="redirect" value="<%= redirect %>">
      <div style="text-align: center; margin-bottom: 20px;">
        <p style="font-size: 13px; color: var(--gray-400); line-height: 1.5;">Kayıtlı e-posta adresinizi girin. Şifrenizi sıfırlamanız için size bir bağlantı göndereceğiz.</p>
      </div>
      <div class="form-group">
        <label>E-posta</label>
        <input type="email" name="email" placeholder="ornek@mail.com" required>
      </div>
      <button type="submit" class="btn-auth">Bağlantı Gönder</button>
    </form>

    <div class="auth-footer" id="loginFooter" style="<%= tab === 'login' ? '' : 'display:none' %>">
      Hesabınız yok mu? <a href="#" onclick="switchTab('register'); return false;">Üye Ol</a>
    </div>
    <div class="auth-footer" id="registerFooter" style="<%= tab === 'register' ? '' : 'display:none' %>">
      Zaten üye misiniz? <a href="#" onclick="switchTab('login'); return false;">Giriş Yap</a>
    </div>
    <div class="auth-footer" id="forgotFooter" style="<%= tab === 'forgot' ? '' : 'display:none' %>">
      Giriş sayfasına geri dönmek için <a href="#" onclick="switchTab('login'); return false;">Giriş Yap</a>
    </div>
  </div>
</div>

<script>
  function switchTab(tab) {
    document.querySelectorAll('.auth-tab').forEach(function(t) { t.classList.remove('active'); });
    document.querySelectorAll('.auth-form').forEach(function(f) { f.classList.remove('active'); });
    
    document.getElementById('loginFooter').style.display = 'none';
    document.getElementById('registerFooter').style.display = 'none';
    document.getElementById('forgotFooter').style.display = 'none';

    if (tab === 'login') {
      document.querySelectorAll('.auth-tab')[0].classList.add('active');
      document.getElementById('loginForm').classList.add('active');
      document.getElementById('loginFooter').style.display = '';
    } else if (tab === 'register') {
      document.querySelectorAll('.auth-tab')[1].classList.add('active');
      document.getElementById('registerForm').classList.add('active');
      document.getElementById('registerFooter').style.display = '';
    } else if (tab === 'forgot') {
      document.getElementById('forgotForm').classList.add('active');
      document.getElementById('forgotFooter').style.display = '';
    }
  }
</script>
</body>
</html>
