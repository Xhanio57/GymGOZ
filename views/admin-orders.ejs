<%- include('layout', { 
  title: 'Sipariş Yönetimi',
  body: `
    <div class="orders-container">
      <h2>📦 İnternet Siparişleri (e-Ticaret)</h2>
      
      <div class="filters">
        <div class="filter-group">
          <label>Ödeme Durumu:</label>
          <select id="filterPayment" onchange="renderOrders()">
            <option value="all">Tümü</option>
            <option value="paid" selected>Ödendi (Başarılı)</option>
            <option value="pending">Beklemede</option>
            <option value="failed">Başarısız / Hata</option>
          </select>
        </div>
        <div class="filter-group">
          <label>Kargo Durumu:</label>
          <select id="filterShipping" onchange="renderOrders()">
            <option value="all">Tümü</option>
            <option value="preparing">Hazırlanıyor</option>
            <option value="shipped">Kargoya Verildi</option>
            <option value="delivered">Teslim Edildi</option>
          </select>
        </div>
        <button onclick="loadAllOrders()" class="btn btn-secondary" style="margin-left:auto;">🔄 Yenile</button>
      </div>

      <table class="orders-table">
        <thead>
          <tr>
            <th>Tarih</th>
            <th>Sipariş No</th>
            <th>Müşteri Bilgileri</th>
            <th>Ürünler</th>
            <th>Toplam</th>
            <th>Ödeme</th>
            <th>Kargo Durumu</th>
            <th>Kargo Takip No</th>
            <th>İşlem</th>
          </tr>
        </thead>
        <tbody id="orders-list">
          <tr>
            <td colspan="9" style="text-align: center; padding: 40px; color: #888;">Yükleniyor...</td>
          </tr>
        </tbody>
      </table>

      <div class="summary">
        <div class="card">
          <h4>Toplam Sipariş</h4>
          <p id="summaryOrders">0</p>
        </div>
        <div class="card">
          <h4>Toplam Ciro</h4>
          <p id="summaryRevenue">0.00 ₺</p>
        </div>
        <div class="card">
          <h4>Bekleyen Gönderi</h4>
          <p id="summaryPending">0</p>
        </div>
      </div>
    </div>

    <style>
      .orders-container {
        background: white;
        padding: 30px;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      }
      .orders-container h2 { margin-bottom: 20px; color: #333; }
      .filters { display: flex; gap: 20px; margin-bottom: 25px; align-items: center; }
      .filter-group { display: flex; align-items: center; gap: 8px; }
      .filter-group select { padding: 8px; border: 1px solid #ddd; border-radius: 6px; font-size: 13px; outline: none; }
      
      .orders-table { width: 100%; border-collapse: collapse; margin-bottom: 30px; }
      .orders-table th { background: #f5f5f5; padding: 12px; text-align: left; border-bottom: 2px solid #ddd; font-weight: 600; font-size: 13px; }
      .orders-table td { padding: 12px 10px; border-bottom: 1px solid #eee; font-size: 13px; vertical-align: top; }
      .orders-table tr:hover { background: #f9f9f9; }

      .badge { display: inline-block; padding: 4px 8px; border-radius: 4px; font-size: 10px; font-weight: 700; color: white; text-align: center; }
      .badge-success { background: #10b981; }
      .badge-warning { background: #f59e0b; }
      .badge-danger { background: #ef4444; }

      .ship-select { padding: 6px 8px; border: 1px solid #ddd; border-radius: 4px; font-size: 12px; outline: none; background: white; }
      .cargo-inp { width: 120px; padding: 6px 8px; border: 1px solid #ddd; border-radius: 4px; font-size: 12px; outline: none; }
      .cargo-inp:focus { border-color: #2563eb; }

      .save-btn { background: #2563eb; color: white; border: 0; padding: 6px 12px; border-radius: 4px; cursor: pointer; font-size: 11px; font-weight: 600; }
      .save-btn:hover { background: #1d4ed8; }

      .summary { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 30px; }
      .card { background: #f5f5f5; padding: 20px; border-radius: 8px; text-align: center; }
      .card h4 { color: #666; font-size: 12px; margin-bottom: 10px; text-transform: uppercase; }
      .card p { font-size: 24px; font-weight: bold; color: #2563eb; }
      
      .btn-secondary { background: #6b7280; color: white; border: none; padding: 8px 16px; border-radius: 6px; cursor: pointer; font-size: 13px; font-weight: 500; }
      .btn-secondary:hover { background: #4b5563; }
    </style>

    <script>
      let allOrders = [];

      async function loadAllOrders() {
        try {
          const res = await fetch('/api/admin/orders');
          allOrders = await res.json();
          renderOrders();
        } catch (err) {
          alert('Siparişler yüklenemedi: ' + err.message);
        }
      }

      function renderOrders() {
        const container = document.getElementById('orders-list');
        const payVal = document.getElementById('filterPayment').value;
        const shipVal = document.getElementById('filterShipping').value;

        if (allOrders.length === 0) {
          container.innerHTML = '<tr><td colspan="9" style="text-align: center; padding: 40px; color: #888;">Henüz kayıtlı bir sipariş bulunmuyor.</td></tr>';
          updateSummary([]);
          return;
        }

        // Filter orders
        const filtered = allOrders.filter(order => {
          const matchPay = (payVal === 'all' || order.paymentStatus === payVal);
          const matchShip = (matchPay && (shipVal === 'all' || order.shippingStatus === shipVal));
          return matchPay && matchShip;
        });

        if (filtered.length === 0) {
          container.innerHTML = '<tr><td colspan="9" style="text-align: center; padding: 40px; color: #888;">Filtrelere uygun sipariş bulunamadı.</td></tr>';
          updateSummary([]);
          return;
        }

        container.innerHTML = filtered.map(order => {
          const d = new Date(order.createdAt);
          const dt = d.toLocaleDateString('tr-TR') + ' ' + d.toLocaleTimeString('tr-TR', {hour: '2-digit', minute:'2-digit'});
          
          // Items list
          const itemsHtml = order.items.map(item => '<li>• ' + item.name + ' (' + item.size + ') x ' + item.quantity + '</li>').join('');

          // Badges
          let payBadge = '';
          if (order.paymentStatus === 'paid') {
            payBadge = '<span class="badge badge-success">ÖDENDİ</span>';
          } else if (order.paymentStatus === 'pending') {
            payBadge = '<span class="badge badge-warning">BEKLEMEDE</span>';
          } else {
            payBadge = '<span class="badge badge-danger">HATA</span>';
          }

          // Selects
          const prepSelected = order.shippingStatus === 'preparing' ? 'selected' : '';
          const shipSelected = order.shippingStatus === 'shipped' ? 'selected' : '';
          const delSelected = order.shippingStatus === 'delivered' ? 'selected' : '';
          
          const shipSelectHtml = '<select class="ship-select" id="ship-' + order._id + '">' +
            '<option value="preparing" ' + prepSelected + '>Hazırlanıyor</option>' +
            '<option value="shipped" ' + shipSelected + '>Kargoya Verildi</option>' +
            '<option value="delivered" ' + delSelected + '>Teslim Edildi</option>' +
            '</select>';

          // Inputs
          const cargoProvider = order.cargoProvider || '';
          const cargoTrackingNo = order.cargoTrackingNo || '';

          return '<tr>' +
            '<td>' + dt + '</td>' +
            '<td style="font-family: monospace; font-size: 11px;">' + order._id + '</td>' +
            '<td>' +
              '<strong>' + order.customerName + '</strong><br>' +
              '<span style="font-size:11px; color:#555;">📞 ' + order.customerPhone + '</span><br>' +
              '<span style="font-size:11px; color:#555;">✉️ ' + order.customerEmail + '</span><br>' +
              '<span style="font-size:11px; color:#666; display:block; max-width:200px; white-space:normal;">' + order.shippingAddress + ' ' + order.shippingDistrict + ' / ' + order.shippingCity + '</span>' +
            '</td>' +
            '<td><ul style="list-style:none; padding:0; margin:0; font-size:12px;">' + itemsHtml + '</ul></td>' +
            '<td><strong>' + order.totalAmount.toFixed(2) + ' ₺</strong></td>' +
            '<td>' + payBadge + '</td>' +
            '<td>' + shipSelectHtml + '</td>' +
            '<td>' +
              '<input type="text" class="cargo-inp" id="provider-' + order._id + '" placeholder="Kargo Firması" value="' + cargoProvider + '"><br>' +
              '<input type="text" class="cargo-inp" id="tracking-' + order._id + '" style="margin-top:4px;" placeholder="Takip No" value="' + cargoTrackingNo + '">' +
            '</td>' +
            '<td><button class="save-btn" onclick="saveCargoDetails(\\\'' + order._id + '\\\')">Kaydet</button></td>' +
            '</tr>';
        }).join('');

        updateSummary(filtered);
      }

      function updateSummary(filteredList) {
        let totalRevenue = 0;
        let totalPending = 0;

        filteredList.forEach(order => {
          if (order.paymentStatus === 'paid') {
            totalRevenue += order.totalAmount;
            if (order.shippingStatus !== 'delivered') {
              totalPending++;
            }
          }
        });

        document.getElementById('summaryOrders').textContent = filteredList.length;
        document.getElementById('summaryRevenue').textContent = totalRevenue.toLocaleString('tr-TR') + ' ₺';
        document.getElementById('summaryPending').textContent = totalPending;
      }

      async function saveCargoDetails(id) {
        const status = document.getElementById('ship-' + id).value;
        const provider = document.getElementById('provider-' + id).value;
        const tracking = document.getElementById('tracking-' + id).value;

        try {
          const res = await fetch('/api/admin/orders/' + id + '/shipping', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              shippingStatus: status,
              cargoProvider: provider,
              cargoTrackingNo: tracking
            })
          });

          const result = await res.json();
          if (result.success) {
            alert('✅ Kargo detayları başarıyla kaydedildi.');
            loadAllOrders(); // Reload list
          } else {
            alert('Hata: ' + result.message);
          }
        } catch (err) {
          alert('Bağlantı hatası: ' + err.message);
        }
      }

      window.addEventListener('DOMContentLoaded', loadAllOrders);
    </script>
  `
}) %>
