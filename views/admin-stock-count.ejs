<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Stok Sayımı | Öz Spor & Outdoor</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #0d0d0f;
      --surface: #141418;
      --surface2: #1c1c22;
      --border: #2a2a32;
      --accent: #d4ff00;
      --text: #f0f0ec;
      --muted: #888884;
      --success: #22c55e;
      --danger: #ff4d4d;
      --warning: #f59e0b;
    }
    html, body { height: 100%; }
    body { font-family: 'Barlow', sans-serif; background: var(--bg); color: var(--text); }
    
    /* HEADER */
    .sc-header {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 14px 16px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 100;
      gap: 12px;
    }
    .sc-logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 18px;
      letter-spacing: 2px;
      color: var(--text);
      text-decoration: none;
      flex-shrink: 0;
    }
    .sc-logo span { color: var(--accent); }
    .sc-progress-wrap { flex: 1; margin: 0 12px; }
    .sc-progress-bar {
      width: 100%;
      height: 6px;
      background: var(--border);
      border-radius: 3px;
      overflow: hidden;
    }
    .sc-progress-fill {
      height: 100%;
      background: var(--accent);
      border-radius: 3px;
      transition: width 0.4s ease;
    }
    .sc-progress-text {
      font-size: 11px;
      color: var(--muted);
      margin-top: 4px;
      text-align: center;
      font-weight: 600;
      letter-spacing: 0.5px;
    }
    .sc-back {
      color: var(--muted);
      text-decoration: none;
      font-size: 12px;
      font-weight: 600;
      padding: 6px 10px;
      border-radius: 6px;
      border: 1px solid var(--border);
      flex-shrink: 0;
      transition: all 0.2s;
    }
    .sc-back:hover { border-color: var(--accent); color: var(--accent); }
    
    /* FILTER BAR */
    .sc-filter {
      padding: 12px 16px;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }
    .sc-search {
      flex: 1;
      min-width: 180px;
      padding: 9px 14px;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--text);
      font-family: 'Barlow', sans-serif;
      font-size: 14px;
      outline: none;
      transition: border-color 0.2s;
    }
    .sc-search:focus { border-color: var(--accent); }
    .sc-cat-filter {
      padding: 9px 12px;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--text);
      font-family: 'Barlow', sans-serif;
      font-size: 13px;
      outline: none;
      cursor: pointer;
    }
    
    /* PRODUCT CARD */
    .sc-list { padding: 12px 16px; display: flex; flex-direction: column; gap: 12px; }
    .sc-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
      transition: border-color 0.2s;
    }
    .sc-card.done { border-color: var(--success); opacity: 0.7; }
    .sc-card.discrepancy { border-color: var(--warning); }
    .sc-card-header {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 14px 14px 12px;
    }
    .sc-card-img {
      width: 52px;
      height: 52px;
      border-radius: 8px;
      object-fit: cover;
      background: var(--surface2);
      flex-shrink: 0;
    }
    .sc-card-info { flex: 1; min-width: 0; }
    .sc-card-name {
      font-weight: 700;
      font-size: 14px;
      color: var(--text);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .sc-card-cat {
      font-size: 11px;
      color: var(--muted);
      margin-top: 2px;
      font-weight: 600;
      letter-spacing: 0.5px;
      text-transform: uppercase;
    }
    .sc-card-badge {
      padding: 4px 10px;
      border-radius: 100px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.5px;
      flex-shrink: 0;
    }
    .sc-badge-pending { background: rgba(136,136,132,0.15); color: var(--muted); }
    .sc-badge-ok { background: rgba(34,197,94,0.15); color: var(--success); }
    .sc-badge-diff { background: rgba(245,158,11,0.15); color: var(--warning); }
    
    /* SIZE ROWS */
    .sc-sizes { padding: 0 14px 14px; }
    .sc-size-row {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 0;
      border-top: 1px solid var(--border);
    }
    .sc-size-label {
      width: 64px;
      font-size: 13px;
      font-weight: 700;
      color: var(--text);
      flex-shrink: 0;
    }
    .sc-size-system {
      flex: 1;
      font-size: 13px;
      color: var(--muted);
    }
    .sc-size-system span { font-weight: 700; color: var(--text); }
    .sc-count-input {
      width: 70px;
      padding: 6px 10px;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 6px;
      color: var(--text);
      font-family: 'Barlow', sans-serif;
      font-size: 14px;
      font-weight: 700;
      text-align: center;
      outline: none;
      transition: border-color 0.2s;
    }
    .sc-count-input:focus { border-color: var(--accent); }
    .sc-count-input.match { border-color: var(--success); background: rgba(34,197,94,0.07); }
    .sc-count-input.differ { border-color: var(--warning); background: rgba(245,158,11,0.07); }
    
    /* ACTIONS */
    .sc-actions {
      display: flex;
      gap: 8px;
      padding: 0 14px 14px;
    }
    .sc-btn {
      flex: 1;
      padding: 11px 14px;
      border-radius: 8px;
      border: none;
      font-family: 'Barlow', sans-serif;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      letter-spacing: 0.5px;
      transition: all 0.2s;
    }
    .sc-btn-ok {
      background: var(--success);
      color: #0d0d0f;
    }
    .sc-btn-ok:hover { opacity: 0.85; transform: scale(0.99); }
    .sc-btn-ok:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }
    .sc-btn-update {
      background: var(--warning);
      color: #0d0d0f;
    }
    .sc-btn-update:hover { opacity: 0.85; }
    .sc-btn-update:disabled { opacity: 0.4; cursor: not-allowed; }
    
    /* TOAST */
    .toast {
      position: fixed;
      bottom: 20px;
      left: 50%;
      transform: translateX(-50%) translateY(100px);
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 12px 20px;
      font-size: 14px;
      font-weight: 600;
      z-index: 9999;
      transition: transform 0.3s ease;
      box-shadow: 0 8px 30px rgba(0,0,0,0.5);
      max-width: 90vw;
    }
    .toast.show { transform: translateX(-50%) translateY(0); }
    .toast.success { border-color: var(--success); color: var(--success); }
    .toast.error { border-color: var(--danger); color: var(--danger); }
    .toast.warning { border-color: var(--warning); color: var(--warning); }
    
    /* EMPTY */
    .sc-empty {
      text-align: center;
      padding: 60px 20px;
      color: var(--muted);
    }
    .sc-empty-icon { font-size: 48px; margin-bottom: 16px; }
    
    /* SUMMARY BANNER */
    .sc-summary {
      position: fixed;
      bottom: 0; left: 0; right: 0;
      background: var(--surface);
      border-top: 1px solid var(--border);
      padding: 12px 16px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      z-index: 50;
    }
    .sc-summary-text { font-size: 12px; color: var(--muted); font-weight: 600; }
    .sc-summary-val { color: var(--text); font-weight: 700; }
    body { padding-bottom: 70px; }
  </style>
</head>
<body>

<header class="sc-header">
  <a href="/admin" class="sc-logo">ÖZ SPOR <span>&</span> OUTDOOR</a>
  <div class="sc-progress-wrap">
    <div class="sc-progress-bar">
      <div class="sc-progress-fill" id="progressFill" style="width:0%"></div>
    </div>
    <div class="sc-progress-text" id="progressText">0 / <%= products.length %> ürün sayıldı</div>
  </div>
  <a href="/admin" class="sc-back">← Geri</a>
</header>

<div class="sc-filter">
  <input type="text" class="sc-search" id="searchInput" placeholder="Ürün ara..." oninput="filterProducts()">
  <select class="sc-cat-filter" id="catFilter" onchange="filterProducts()">
    <option value="">Tüm Kategoriler</option>
    <% const cats = [...new Set(products.map(p => p.category))].sort(); %>
    <% cats.forEach(c => { %><option value="<%= c %>"><%= c %></option><% }); %>
  </select>
</div>

<div class="sc-list" id="productList">
  <% const activeProducts = products.filter(p => (p.sizeStock || []).reduce((t, s) => t + (s.stock || 0), 0) > 0); %>
  <% activeProducts.forEach((product, pi) => { %>
  <div class="sc-card" id="card-<%= product._id %>" data-name="<%= product.name.toLowerCase() %>" data-cat="<%= product.category %>" data-index="<%= pi %>">
    <div class="sc-card-header">
      <img class="sc-card-img" src="<%= product.image %>" alt="<%= product.name %>" onerror="this.src='/images/default-product.png'">
      <div class="sc-card-info">
        <div class="sc-card-name"><%= product.name %></div>
        <div class="sc-card-cat"><%= product.category %></div>
      </div>
      <span class="sc-card-badge sc-badge-pending" id="badge-<%= product._id %>">Bekliyor</span>
    </div>
    <div class="sc-sizes">
      <% const activeSizeStocks = product.sizeStock.filter(ss => ss.stock > 0); %>
      <% activeSizeStocks.forEach((ss, si) => { %>
      <div class="sc-size-row">
        <div class="sc-size-label"><%= ss.size %></div>
        <div class="sc-size-system">Sistem: <span><%= ss.stock %></span></div>
        <input
          type="number"
          min="0"
          class="sc-count-input"
          id="input-<%= product._id %>-<%= si %>"
          data-pid="<%= product._id %>"
          data-si="<%= si %>"
          data-sys="<%= ss.stock %>"
          data-size="<%= ss.size %>"
          placeholder="Sayım"
          oninput="onCountInput(this)"
        >
      </div>
      <% }); %>
    </div>
    <div class="sc-actions">
      <button class="sc-btn sc-btn-ok" id="btn-ok-<%= product._id %>" onclick="confirmProduct('<%= product._id %>')">✓ Stok Doğru</button>
      <button class="sc-btn sc-btn-update" id="btn-upd-<%= product._id %>" onclick="updateProduct('<%= product._id %>')" disabled>↺ Güncelle</button>
    </div>
  </div>
  <% }); %>
</div>

<% if (products.length === 0) { %>
<div class="sc-empty">
  <div class="sc-empty-icon">📦</div>
  <div>Kayıtlı ürün bulunamadı.</div>
</div>
<% } %>

<div class="sc-summary">
  <div class="sc-summary-text">Sayılan: <span class="sc-summary-val" id="countedCount">0</span> / <%= products.length %></div>
  <div class="sc-summary-text">Fark var: <span class="sc-summary-val" id="diffCount">0</span></div>
  <div class="sc-summary-text">Güncellenen: <span class="sc-summary-val" id="updatedCount">0</span></div>
</div>

<div class="toast" id="toast"></div>

<script>
  let countedProducts = new Set();
  let updatedProducts = new Set();
  let diffProducts = new Set();
  const totalProducts = <%= products.length %>;

  function showToast(msg, type = 'success') {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.className = 'toast ' + type;
    setTimeout(() => t.classList.add('show'), 10);
    setTimeout(() => t.classList.remove('show'), 3000);
  }

  function updateProgress() {
    const counted = countedProducts.size;
    const pct = totalProducts > 0 ? (counted / totalProducts * 100) : 0;
    document.getElementById('progressFill').style.width = pct + '%';
    document.getElementById('progressText').textContent = counted + ' / ' + totalProducts + ' ürün sayıldı';
    document.getElementById('countedCount').textContent = counted;
    document.getElementById('diffCount').textContent = diffProducts.size;
    document.getElementById('updatedCount').textContent = updatedProducts.size;
  }

  function onCountInput(input) {
    const pid = input.dataset.pid;
    const sysStock = parseInt(input.dataset.sys) || 0;
    const val = input.value !== '' ? parseInt(input.value) : null;
    
    input.classList.remove('match', 'differ');
    if (val !== null) {
      if (val === sysStock) {
        input.classList.add('match');
      } else {
        input.classList.add('differ');
      }
    }

    // Check all inputs for this product
    const card = document.getElementById('card-' + pid);
    const allInputs = card.querySelectorAll('.sc-count-input');
    let allFilled = true;
    let anyDiff = false;
    allInputs.forEach(inp => {
      const v = inp.value !== '' ? parseInt(inp.value) : null;
      if (v === null) { allFilled = false; return; }
      if (v !== (parseInt(inp.dataset.sys) || 0)) anyDiff = true;
    });

    const btnOk = document.getElementById('btn-ok-' + pid);
    const btnUpd = document.getElementById('btn-upd-' + pid);
    const badge = document.getElementById('badge-' + pid);

    if (allFilled) {
      if (anyDiff) {
        card.classList.add('discrepancy');
        card.classList.remove('done');
        badge.textContent = 'Fark Var';
        badge.className = 'sc-card-badge sc-badge-diff';
        btnOk.disabled = true;
        btnUpd.disabled = false;
      } else {
        card.classList.remove('discrepancy');
        badge.textContent = 'Eşleşiyor';
        badge.className = 'sc-card-badge sc-badge-ok';
        btnOk.disabled = false;
        btnUpd.disabled = true;
      }
    } else {
      badge.textContent = 'Giriliyor...';
      badge.className = 'sc-card-badge sc-badge-pending';
      btnOk.disabled = true;
      btnUpd.disabled = true;
    }
  }

  async function confirmProduct(pid) {
    const card = document.getElementById('card-' + pid);
    const badge = document.getElementById('badge-' + pid);
    const btnOk = document.getElementById('btn-ok-' + pid);
    const btnUpd = document.getElementById('btn-upd-' + pid);
    btnOk.disabled = true;
    btnOk.textContent = '...';

    try {
      const res = await fetch('/api/stock-count/confirm', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ productId: pid })
      });
      const data = await res.json();
      if (data.success) {
        card.classList.add('done');
        badge.textContent = '✓ Onaylandı';
        badge.className = 'sc-card-badge sc-badge-ok';
        btnOk.textContent = '✓ Tamam';
        btnOk.disabled = true;
        btnUpd.disabled = true;
        countedProducts.add(pid);
        diffProducts.delete(pid);
        updateProgress();
        showToast('✓ Stok onaylandı', 'success');
      } else {
        showToast('Hata: ' + data.message, 'error');
        btnOk.textContent = '✓ Stok Doğru';
        btnOk.disabled = false;
      }
    } catch (err) {
      showToast('Bağlantı hatası', 'error');
      btnOk.textContent = '✓ Stok Doğru';
      btnOk.disabled = false;
    }
  }

  async function updateProduct(pid) {
    const card = document.getElementById('card-' + pid);
    const badge = document.getElementById('badge-' + pid);
    const btnUpd = document.getElementById('btn-upd-' + pid);
    const btnOk = document.getElementById('btn-ok-' + pid);
    const allInputs = card.querySelectorAll('.sc-count-input');
    btnUpd.disabled = true;
    btnUpd.textContent = '...';

    const updates = [];
    allInputs.forEach(inp => {
      updates.push({
        size: inp.dataset.size,
        si: parseInt(inp.dataset.si),
        actualCount: parseInt(inp.value) || 0,
        systemCount: parseInt(inp.dataset.sys) || 0
      });
    });

    try {
      const res = await fetch('/api/stock-count/update', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ productId: pid, updates })
      });
      const data = await res.json();
      if (data.success) {
        card.classList.add('done');
        card.classList.remove('discrepancy');
        badge.textContent = '↺ Güncellendi';
        badge.className = 'sc-card-badge sc-badge-ok';
        btnUpd.textContent = '✓ Güncellendi';
        btnOk.disabled = true;
        // Update system stock display
        allInputs.forEach(inp => {
          const row = inp.closest('.sc-size-row');
          if (row) {
            const sysEl = row.querySelector('.sc-size-system span');
            if (sysEl) sysEl.textContent = inp.value;
          }
          inp.dataset.sys = inp.value;
          inp.classList.remove('differ');
          inp.classList.add('match');
        });
        countedProducts.add(pid);
        diffProducts.delete(pid);
        updatedProducts.add(pid);
        updateProgress();
        showToast('↺ Stok güncellendi ve kayıt oluşturuldu', 'warning');
      } else {
        showToast('Hata: ' + data.message, 'error');
        btnUpd.textContent = '↺ Güncelle';
        btnUpd.disabled = false;
      }
    } catch (err) {
      showToast('Bağlantı hatası', 'error');
      btnUpd.textContent = '↺ Güncelle';
      btnUpd.disabled = false;
    }
  }

  function filterProducts() {
    const search = document.getElementById('searchInput').value.toLowerCase();
    const cat = document.getElementById('catFilter').value;
    document.querySelectorAll('.sc-card').forEach(card => {
      const name = card.dataset.name || '';
      const cardCat = card.dataset.cat || '';
      const matchSearch = !search || name.includes(search);
      const matchCat = !cat || cardCat === cat;
      card.style.display = (matchSearch && matchCat) ? '' : 'none';
    });
  }
</script>
</body>
</html>
