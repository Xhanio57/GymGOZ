<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Yeniden Ödeme Yap | Öz Spor & Outdoor</title>
  <link rel="icon" type="image/png" href="/images/default-product.png">
  <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700;800&family=Bebas+Neue&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --black: #0a0a0a;
      --white: #f5f5f0;
      --accent: #d4ff00;
      --gray-400: #999990;
      --gray-600: #555550;
      --nav-h: 64px;
    }
    body {
      font-family: 'Barlow', sans-serif;
      background: var(--black);
      color: var(--white);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      padding-top: var(--nav-h);
    }
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      height: var(--nav-h);
      background: var(--black);
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 28px;
      border-bottom: 2px solid #1a1a1a;
    }
    .nav-logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 22px; letter-spacing: 2px;
      color: var(--white); text-decoration: none;
    }
    .nav-logo span { color: var(--accent); }
    .back-btn {
      color: var(--gray-400);
      text-decoration: none;
      font-size: 13px;
      font-weight: 500;
    }
    .back-btn:hover {
      color: var(--accent);
    }
    .retry-container {
      max-width: 800px;
      width: 100%;
      margin: 40px auto;
      padding: 0 24px;
      flex: 1;
    }
    .retry-box {
      background: rgba(255,255,255,0.02);
      border: 1px solid rgba(255,255,255,0.08);
      padding: 32px;
      border-radius: 12px;
      box-shadow: 0 4px 30px rgba(0,0,0,0.4);
    }
    .retry-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 28px;
      letter-spacing: 2px;
      margin-bottom: 20px;
      border-bottom: 2px solid var(--accent);
      padding-bottom: 12px;
      color: var(--white);
    }
    .retry-info {
      font-size: 14px;
      color: var(--gray-400);
      margin-bottom: 24px;
      line-height: 1.6;
    }
    .retry-info strong {
      color: var(--white);
    }
  </style>
</head>
<body>
  <nav>
    <a href="/" class="nav-logo">Öz Spor <span>&</span> Outdoor</a>
    <a href="/account" class="back-btn">← Hesabıma Dön</a>
  </nav>

  <div class="retry-container">
    <div class="retry-box">
      <h2 class="retry-title">🔒 Güvenli Ödeme Tekrarı</h2>
      <div class="retry-info">
        <strong>Sipariş No:</strong> #<%= order._id.toString().slice(-8).toUpperCase() %><br>
        <strong>Ödeme Tutarı:</strong> <%= order.totalAmount.toFixed(2) %> ₺
      </div>
      
      <iframe src="https://www.paytr.com/odeme/guvenli/<%= token %>" id="paytriframe" frameborder="0" scrolling="no" style="width: 100%; min-height: 600px;"></iframe>
    </div>
  </div>

  <script src="https://www.paytr.com/js/iframeResizer.min.js"></script>
  <script>
    window.addEventListener('DOMContentLoaded', () => {
      iFrameResize({}, '#paytriframe');
    });
  </script>
</body>
</html>
