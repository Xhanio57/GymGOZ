<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Güvenli Ödeme | Öz Spor & Outdoor</title>
  <link rel="icon" type="image/png" href="/images/default-product.png">
  <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700;800&family=Bebas+Neue&display=swap" rel="stylesheet">
  <style>
    :root {
      --black: #000000;
      --white: #ffffff;
      --gray-50: #f9fafb;
      --gray-100: #f3f4f6;
      --gray-200: #e5e7eb;
      --gray-300: #d1d5db;
      --gray-400: #9ca3af;
      --gray-500: #6b7280;
      --gray-600: #4b5563;
      --accent: #d4ff00;
      --red: #dc2626;
      --nav-h: 64px;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Barlow', sans-serif;
      background: var(--gray-50);
      color: var(--black);
      padding-top: var(--nav-h);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ===== NAVBAR ===== */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      height: var(--nav-h);
      background: var(--black);
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 28px;
      border-bottom: 2px solid #1a1a1a;
    }
    .nav-logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 22px; letter-spacing: 2px;
      color: var(--white); text-decoration: none;
    }
    .nav-logo span { color: var(--accent); }
    .back-btn {
      color: var(--white);
      text-decoration: none;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 1px;
      text-transform: uppercase;
      transition: color 0.2s;
    }
    .back-btn:hover {
      color: var(--accent);
    }

    /* ===== MAIN CONTAINER ===== */
    .checkout-container {
      max-width: 1100px;
      width: 100%;
      margin: 40px auto;
      padding: 0 24px;
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 40px;
      flex: 1;
    }

    @media (max-width: 900px) {
      .checkout-container {
        grid-template-columns: 1fr;
        margin: 20px auto;
      }
    }

    /* ===== CARDS & BOXES ===== */
    .checkout-box {
      background: var(--white);
      border: 1px solid var(--gray-200);
      padding: 32px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.02);
      border-radius: 4px;
    }
    .checkout-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 24px;
      letter-spacing: 2px;
      margin-bottom: 24px;
      border-bottom: 1px solid var(--gray-200);
      padding-bottom: 12px;
      text-transform: uppercase;
    }

    /* ===== FORM FIELDS ===== */
    .form-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-bottom: 24px;
    }
    .form-group {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .form-group.full-width {
      grid-column: span 2;
    }
    .form-label {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--gray-600);
    }
    .form-input {
      width: 100%;
      padding: 12px 16px;
      border: 1px solid var(--gray-300);
      background: var(--white);
      font-size: 14px;
      border-radius: 4px;
      outline: none;
      transition: border-color 0.2s;
    }
    .form-input:focus {
      border-color: var(--black);
    }

    /* ===== CHECKOUT BUTTON ===== */
    .submit-btn {
      width: 100%;
      padding: 16px;
      background: var(--black);
      color: var(--white);
      border: none;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      cursor: pointer;
      transition: background 0.2s, color 0.2s;
      border-radius: 4px;
    }
    .submit-btn:hover {
      background: #222;
      color: var(--accent);
    }

    /* ===== ORDER SUMMARY ===== */
    .summary-items {
      display: flex;
      flex-direction: column;
      gap: 16px;
      margin-bottom: 24px;
    }
    .summary-item {
      display: flex;
      gap: 12px;
      align-items: center;
    }
    .summary-item img {
      width: 60px;
      height: 60px;
      object-fit: cover;
      border-radius: 4px;
      border: 1px solid var(--gray-200);
    }
    .summary-item-details {
      flex: 1;
    }
    .summary-item-name {
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
    }
    .summary-item-meta {
      font-size: 11px;
      color: var(--gray-500);
      margin-top: 2px;
    }
    .summary-item-price {
      font-size: 13px;
      font-weight: 600;
      margin-top: 4px;
    }

    .price-row {
      display: flex;
      justify-content: space-between;
      font-size: 14px;
      color: var(--gray-600);
      margin-bottom: 8px;
    }
    .price-row.total {
      font-size: 18px;
      font-weight: 800;
      color: var(--black);
      border-top: 1px solid var(--gray-200);
      padding-top: 12px;
      margin-top: 12px;
    }

    /* ===== IYZICO FORM WRAPPER ===== */
    #payment-form-container {
      margin-top: 24px;
    }
    .loader {
      display: none;
      border: 4px solid var(--gray-200);
      border-top: 4px solid var(--black);
      border-radius: 50%;
      width: 32px;
      height: 32px;
      animation: spin 1s linear infinite;
      margin: 20px auto;
    }
    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }
    .loader-text {
      display: none;
      font-size: 12px;
      font-weight: 600;
      text-align: center;
      color: var(--gray-500);
      margin-top: 8px;
    }
  </style>
</head>
<body>

  <!-- ===== NAVBAR ===== -->
  <nav>
    <a href="/products" class="nav-logo">Öz Spor <span>&</span> Outdoor</a>
    <a href="/products" class="back-btn">← Alışverişe Dön</a>
  </nav>

  <!-- ===== MAIN CONTENT ===== -->
  <div class="checkout-container">
    
    <!-- LEFT COLUMN: Address Form & iyzico Iframe -->
    <div>
      <div class="checkout-box" id="address-box">
        <h2 class="checkout-title">Teslimat & İletişim Bilgileri</h2>
        <form id="checkout-form" onsubmit="initiatePayment(event)">
          <!-- Contact Details (Readonly mostly) -->
          <div class="form-grid" style="grid-template-columns: 1fr; gap: 16px; margin-bottom: 24px;">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
              <div class="form-group">
                <label class="form-label">Ad Soyad</label>
                <input type="text" class="form-input" value="<%= customer.firstName %> <%= customer.lastName %>" readonly style="background: var(--gray-100); color: var(--gray-500); cursor: not-allowed;">
              </div>
              <div class="form-group">
                <label class="form-label">E-posta Adresi</label>
                <input type="email" class="form-input" value="<%= customer.email %>" readonly style="background: var(--gray-100); color: var(--gray-500); cursor: not-allowed;">
              </div>
            </div>
            
            <div class="form-group">
              <label class="form-label">Telefon Numarası</label>
              <input type="tel" id="customerPhone" class="form-input" value="<%= customer.phone || '' %>" <%= customer.phone ? 'readonly' : 'required' %> style="<%= customer.phone ? 'background: var(--gray-100); color: var(--gray-500); cursor: not-allowed;' : '' %>" placeholder="05XX XXX XX XX">
            </div>
          </div>

          <!-- Address selection -->
          <% if (customer.addresses && customer.addresses.length > 0) { %>
            <div style="display: flex; flex-direction: column; gap: 12px; margin-bottom: 24px;">
              <label class="form-label" style="font-weight: 700;">Gönderim Adresi Seçin</label>
              <% customer.addresses.forEach(function(addr, idx) { %>
                <label class="address-option" style="display: flex; align-items: flex-start; gap: 12px; padding: 16px; border: 1px solid var(--gray-200); border-radius: 6px; cursor: pointer; transition: border-color 0.2s;">
                  <input type="radio" name="selectedAddress" value="<%= idx %>" <%= idx === 0 ? 'checked' : '' %> style="margin-top: 4px; accent-color: var(--black);"
                         data-title="<%= addr.title %>"
                         data-address="<%= addr.fullAddress %>"
                         data-city="<%= addr.city %>"
                         data-district="<%= addr.district %>"
                         data-zip="<%= addr.zipCode %>">
                  <div>
                    <strong style="display: block; font-size: 13px; text-transform: uppercase;"><%= addr.title %></strong>
                    <span style="display: block; font-size: 12px; color: var(--gray-600); margin-top: 4px;"><%= addr.fullAddress %></span>
                    <span style="display: block; font-size: 11px; color: var(--gray-500); margin-top: 2px;"><%= addr.district %> / <%= addr.city %></span>
                  </div>
                </label>
              <% }); %>
            </div>
            <div style="margin-bottom: 20px; display: flex; flex-direction: column; gap: 10px; font-size: 12px; color: var(--gray-600);">
              <label style="display: flex; align-items: flex-start; gap: 8px; cursor: pointer;">
                <input type="checkbox" id="chkKvkk" required style="margin-top: 3px; accent-color: var(--black);">
                <span><a href="/kvkk" target="_blank" style="color: var(--black); font-weight: 600; text-decoration: underline;">KVKK Aydınlatma Metni</a>'ni okudum ve verilerimin işlenmesini kabul ediyorum.</span>
              </label>
              <label style="display: flex; align-items: flex-start; gap: 8px; cursor: pointer;">
                <input type="checkbox" id="chkMss" required style="margin-top: 3px; accent-color: var(--black);">
                <span><a href="/mss" target="_blank" style="color: var(--black); font-weight: 600; text-decoration: underline;">Mesafeli Satış Sözleşmesi</a>'ni ve <a href="/obf" target="_blank" style="color: var(--black); font-weight: 600; text-decoration: underline;">Ön Bilgilendirme Formu</a>'nu okudum, onaylıyorum.</span>
              </label>
            </div>
            <button type="submit" class="submit-btn" id="pay-submit-btn">Ödeme Bilgilerine Geç</button>
          <% } else { %>
            <div style="padding: 24px; border: 1px dashed var(--red); border-radius: 8px; background: rgba(220, 38, 38, 0.02); text-align: center; margin-bottom: 24px;">
              <p style="font-size: 14px; font-weight: 700; color: var(--red); margin-bottom: 8px;">Kayıtlı Adres Bulunmadı</p>
              <p style="font-size: 12px; color: var(--gray-500); margin-bottom: 16px; line-height: 1.5;">Siparişinizi tamamlayabilmek için en az bir teslimat adresi tanımlamış olmanız gerekmektedir.</p>
              <a href="/account" class="submit-btn" style="text-decoration: none; display: block; text-align: center; font-size: 12px; padding: 12px;">Yeni Adres Ekle / Hesabım</a>
            </div>
            <button type="button" class="submit-btn" style="opacity: 0.4; cursor: not-allowed;" disabled>Ödeme Bilgilerine Geç</button>
          <% } %>
        </form>
      </div>

      <!-- Spinner Loader -->
      <div class="loader" id="checkout-loader"></div>
      <div class="loader-text" id="checkout-loader-text">Ödeme güvenli kanalı açılıyor, lütfen bekleyin...</div>

      <!-- Dynamic PayTR Form container -->
      <div class="checkout-box" id="payment-form-container" style="display: none;">
        <h2 class="checkout-title" style="border-bottom: 2px solid var(--accent);">🔒 Güvenli Kredi Kartı Ödemesi</h2>
        <div id="paytr-checkout-form" class="responsive"></div>
      </div>
    </div>

    <!-- RIGHT COLUMN: Order Summary -->
    <div>
      <div class="checkout-box">
        <h2 class="checkout-title">Sipariş Özeti</h2>
        
        <!-- Free Shipping Warning -->
        <div id="freeShippingWarning" style="margin-bottom: 20px; padding: 12px; background: rgba(245, 158, 11, 0.08); border-left: 4px solid #f59e0b; border-radius: 4px; font-size: 13px; color: #b45309; display: none; line-height: 1.5;">
          Siparişinizin ücretsiz kargo ile teslim edilmesini istiyorsanız <strong id="warningDiffAmount">0.00</strong> ₺ daha ekleme yapmanız gerekmektedir.
        </div>

        <div class="summary-items" id="summaryItemsContainer">
          <!-- Populated dynamically from localStorage -->
        </div>
        
        <div class="price-row">
          <span>Ara Toplam (KDV Hariç)</span>
          <span id="summarySubtotal">0.00 TL</span>
        </div>
        <div class="price-row" id="couponDiscountRow" style="display: none; color: #ff4d4d;">
          <span>Kupon İndirimi (<span id="couponCodeLabel"></span>)</span>
          <span id="summaryDiscount">-0.00 TL</span>
        </div>
        <div class="price-row">
          <span>KDV (%20)</span>
          <span id="summaryVat">0.00 TL</span>
        </div>
        <div class="price-row">
          <span>Kargo</span>
          <span id="summaryShipping" style="color: #2d8c40; font-weight: 700;">ÜCRETSİZ</span>
        </div>
        <div class="price-row total">
          <span>Genel Toplam</span>
          <span id="summaryTotal">0.00 TL</span>
        </div>
        <div style="margin-top: 20px; padding-top: 15px; border-top: 1px solid var(--gray-200); display: flex; gap: 8px;">
          <input type="text" id="couponCodeInp" placeholder="KUPON KODU" style="flex: 1; padding: 10px; border: 1px solid var(--gray-300); border-radius: 6px; text-transform: uppercase; font-family: inherit; font-size: 13px;">
          <button type="button" onclick="applyCoupon()" style="padding: 10px 16px; background: var(--black); color: var(--accent); border: 1px solid var(--black); border-radius: 6px; font-weight: 700; cursor: pointer; font-size: 12px; text-transform: uppercase;">Uygula</button>
        </div>
      </div>
    </div>

  </div>

  <script>
    let cart = [];
    let appliedCoupon = null;
    let discountAmount = 0;

    // Load cart items from localStorage on page load
    function loadCheckoutSummary() {
      const savedCart = localStorage.getItem('gymgoz_cart');
      if (savedCart) {
        try {
          cart = JSON.parse(savedCart);
        } catch (e) {
          cart = [];
        }
      }

      if (cart.length === 0) {
        alert('Sepetiniz boş! Alışveriş sayfasına yönlendiriliyorsunuz.');
        window.location.href = '/products';
        return;
      }

      const container = document.getElementById('summaryItemsContainer');
      container.innerHTML = cart.map(item => `
        <div class="summary-item">
          <img src="${item.image}" onerror="this.src='/images/default-product.png'">
          <div class="summary-item-details">
            <div class="summary-item-name">${item.name}</div>
            <div class="summary-item-meta">Beden: ${item.size} | Adet: ${item.quantity}</div>
            <div class="summary-item-price">${(item.price * item.quantity).toLocaleString('tr-TR')} TL</div>
          </div>
        </div>
      `).join('');

      updatePrices();
    }

    function updatePrices() {
      const baseTotal = cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);
      const finalProductTotal = baseTotal - discountAmount;
      
      let shippingFee = 0;
      const warningBox = document.getElementById('freeShippingWarning');
      const warningDiff = document.getElementById('warningDiffAmount');
      const shippingLabel = document.getElementById('summaryShipping');

      if (finalProductTotal < 3000) {
        shippingFee = 89.99;
        const diff = 3000 - finalProductTotal;
        warningDiff.textContent = diff.toLocaleString('tr-TR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        warningBox.style.display = 'block';
        shippingLabel.textContent = '89,99 ₺';
        shippingLabel.style.color = 'var(--black)';
        shippingLabel.style.fontWeight = '600';
      } else {
        shippingFee = 0;
        warningBox.style.display = 'none';
        shippingLabel.textContent = 'ÜCRETSİZ';
        shippingLabel.style.color = '#2d8c40';
        shippingLabel.style.fontWeight = '700';
      }

      const finalTotal = finalProductTotal + shippingFee;
      const subtotal = finalTotal / 1.2;
      const vat = finalTotal - subtotal;

      document.getElementById('summarySubtotal').textContent = subtotal.toLocaleString('tr-TR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' ₺';
      document.getElementById('summaryVat').textContent = vat.toLocaleString('tr-TR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' ₺';
      document.getElementById('summaryTotal').textContent = finalTotal.toLocaleString('tr-TR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' ₺';

      if (discountAmount > 0) {
        document.getElementById('couponCodeLabel').textContent = appliedCoupon.code;
        document.getElementById('summaryDiscount').textContent = '-' + discountAmount.toLocaleString('tr-TR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' ₺';
        document.getElementById('couponDiscountRow').style.display = 'flex';
      } else {
        document.getElementById('couponDiscountRow').style.display = 'none';
      }
    }

    async function applyCoupon() {
      const code = document.getElementById('couponCodeInp').value.trim();
      if (!code) {
        alert('Lütfen geçerli bir kupon kodu girin.');
        return;
      }

      const cartAmount = cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);

      try {
        const res = await fetch('/api/coupons/apply', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ code, cartAmount })
        });
        const result = await res.json();
        if (result.success) {
          appliedCoupon = result.coupon;
          discountAmount = result.discountAmount;
          
          alert(`Kupon uygulandı! İndirim: ${discountAmount.toFixed(2)} ₺`);
          updatePrices();
        } else {
          alert(result.message);
        }
      } catch (err) {
        alert('Kupon kontrol edilirken hata oluştu.');
      }
    }

    async function initiatePayment(event) {
      event.preventDefault();
      
      const submitBtn = document.getElementById('pay-submit-btn');
      const loader = document.getElementById('checkout-loader');
      const loaderText = document.getElementById('checkout-loader-text');
      const paymentContainer = document.getElementById('payment-form-container');

      const selectedRadio = document.querySelector('input[name="selectedAddress"]:checked');
      if (!selectedRadio) {
        alert('Lütfen bir teslimat adresi seçin.');
        return;
      }

      // Show loader
      submitBtn.disabled = true;
      submitBtn.style.opacity = '0.5';
      loader.style.display = 'block';
      loaderText.style.display = 'block';

      // Gather form inputs from customer EJS model and selected address
      const payload = {
        customerName: "<%= customer.firstName %> <%= customer.lastName %>",
        customerPhone: document.getElementById('customerPhone').value,
        customerEmail: "<%= customer.email %>",
        shippingZip: selectedRadio.dataset.zip || '',
        shippingCity: selectedRadio.dataset.city,
        shippingDistrict: selectedRadio.dataset.district,
        shippingAddress: selectedRadio.dataset.address,
        couponCode: appliedCoupon ? appliedCoupon.code : '',
        items: cart.map(item => ({
          productId: item.productId,
          name: item.name,
          size: item.size,
          quantity: item.quantity
        }))
      };

      try {
        const response = await fetch('/api/checkout/initiate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });

        const result = await response.json();

        if (!result.success) {
          alert('Ödeme başlatılamadı: ' + result.message);
          if (result.orderCreated) {
            // Since the order was created in DB, clear the cart and redirect to account retry page
            localStorage.removeItem('gymgoz_cart');
            window.location.href = '/account';
          } else {
            submitBtn.disabled = false;
            submitBtn.style.opacity = '1';
            loader.style.display = 'none';
            loaderText.style.display = 'none';
          }
          return;
        }

        // Clear customer cart since the order has been created and registered
        localStorage.removeItem('gymgoz_cart');

        // Hide form box and display payment form
        document.getElementById('address-box').style.display = 'none';
        loader.style.display = 'none';
        loaderText.style.display = 'none';
        paymentContainer.style.display = 'block';

        // Render PayTR iframe
        paymentContainer.innerHTML = `
          <h2 class="checkout-title" style="border-bottom: 2px solid var(--accent); margin-bottom: 20px;">🔒 Güvenli Kredi Kartı Ödemesi</h2>
          <iframe src="https://www.paytr.com/odeme/guvenli/${result.token}" id="paytriframe" frameborder="0" scrolling="no" style="width: 100%; min-height: 600px;"></iframe>
        `;

        // Dynamically load PayTR iframe resizer script to dynamically adjust iframe height
        const iframeScript = document.createElement('script');
        iframeScript.src = "https://www.paytr.com/js/iframeResizer.min.js";
        document.body.appendChild(iframeScript);
        iframeScript.onload = () => {
          iFrameResize({}, '#paytriframe');
        };

      } catch (err) {
        alert('İşlem başlatılırken sunucu hatası oluştu: ' + err.message);
        submitBtn.disabled = false;
        submitBtn.style.opacity = '1';
        loader.style.display = 'none';
        loaderText.style.display = 'none';
      }
    }

    window.addEventListener('DOMContentLoaded', loadCheckoutSummary);
  </script>
</body>
</html>
