<%- include('layout', { 
  title: 'Kupon Yönetimi',
  body: `
  <div class="settings-container">
    <h2>🎫 Kupon Yönetimi (İndirim Kampanyaları)</h2>
    
    <div class="settings-grid">
      <!-- KUPON OLUŞTURMA -->
      <div class="settings-card">
        <h3>➕ Yeni İndirim Kuponu Ekle</h3>
        
        <form id="couponForm" class="settings-form">
          <div class="form-group">
            <label for="code">Kupon Kodu (Büyük Harf Olur)</label>
            <input type="text" id="code" placeholder="Örn: SPOR20" style="text-transform: uppercase;" required>
          </div>
          <div class="form-group" style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
            <div>
              <label for="type">İndirim Türü</label>
              <select id="type" required>
                <option value="percentage">Yüzde (%)</option>
                <option value="flat">Sabit Tutar (₺)</option>
              </select>
            </div>
            <div>
              <label for="value">Değer</label>
              <input type="number" id="value" placeholder="Örn: 20 VEYA 150" min="0" required>
            </div>
          </div>
          <div class="form-group">
            <label for="minOrderAmount">Min. Sepet Tutarı (₺)</label>
            <input type="number" id="minOrderAmount" placeholder="Örn: 500" min="0" value="0">
          </div>
          <div class="form-group" style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
            <div>
              <label for="startDate">Başlangıç Tarihi</label>
              <input type="date" id="startDate" required>
            </div>
            <div>
              <label for="endDate">Bitiş Tarihi</label>
              <input type="date" id="endDate" required>
            </div>
          </div>
          <button type="submit" class="btn btn-primary w-100">Kupon Oluştur</button>
        </form>
      </div>

      <!-- KUPON LİSTESİ -->
      <div class="settings-card">
        <h3>📋 Aktif Kuponlar</h3>
        
        <div id="couponsList" class="settings-list">
          <div style="text-align: center; padding: 20px; color: var(--adm-muted);">Kuponlar yükleniyor...</div>
        </div>
      </div>
    </div>
  </div>

  <style>
    .settings-container {
      background: var(--adm-surface, #141418);
      padding: 30px;
      border-radius: 8px;
      color: var(--adm-text, #f0f0ec);
    }
    .settings-container h2 {
      margin-bottom: 25px;
      color: var(--adm-accent, #d4ff00);
      font-family: 'Bebas Neue', sans-serif;
      letter-spacing: 2px;
      font-size: 32px;
    }
    .settings-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 30px;
    }
    @media(max-width: 900px) {
      .settings-grid { grid-template-columns: 1fr; }
    }
    .settings-card {
      background: var(--adm-surface2, #1c1c22);
      border: 1px solid var(--adm-border, #2a2a32);
      border-radius: 8px;
      padding: 20px;
      color: var(--adm-text, #f0f0ec);
    }
    .settings-card h3 {
      margin-top: 0;
      color: var(--adm-accent, #d4ff00);
      margin-bottom: 15px;
      border-bottom: 2px solid var(--adm-border, #2a2a32);
      padding-bottom: 8px;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 20px;
      letter-spacing: 1px;
    }
    .settings-form {
      margin-bottom: 15px;
    }
    .form-group {
      margin-bottom: 12px;
    }
    .form-group label {
      display: block;
      font-size: 12px;
      font-weight: 600;
      margin-bottom: 4px;
      color: var(--adm-muted, #888884);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .form-group input, .form-group select {
      width: 100%;
      padding: 10px;
      background: var(--adm-surface, #0d0d0f);
      border: 1px solid var(--adm-border, #2a2a32);
      border-radius: 6px;
      color: var(--adm-text, #f0f0ec);
      font-family: inherit;
      outline: none;
    }
    .form-group input:focus, .form-group select:focus {
      border-color: var(--adm-accent, #d4ff00);
    }
    .btn {
      padding: 10px 18px;
      border-radius: 6px;
      font-weight: 700;
      font-size: 13px;
      cursor: pointer;
      text-transform: uppercase;
      transition: all 0.2s;
      border: none;
    }
    .btn-primary {
      background: var(--adm-accent, #d4ff00);
      color: #0d0d0f;
    }
    .btn-primary:hover {
      opacity: 0.9;
    }
    .w-100 { width: 100%; }
    .settings-list {
      display: flex;
      flex-direction: column;
      gap: 12px;
      max-height: 450px;
      overflow-y: auto;
    }
    .list-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 16px;
      background: var(--adm-surface, #0d0d0f);
      border: 1px solid var(--adm-border, #2a2a32);
      border-radius: 6px;
    }
    .list-item-info strong {
      color: var(--adm-accent, #d4ff00);
      font-size: 16px;
    }
    .list-item-info p {
      font-size: 12px;
      color: var(--adm-muted, #888884);
      margin-top: 4px;
    }
    .delete-btn {
      background: rgba(255, 77, 77, 0.1);
      color: var(--adm-danger, #ff4d4d);
      border: 1px solid rgba(255, 77, 77, 0.2);
      padding: 6px 12px;
      border-radius: 4px;
      font-size: 11px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.2s;
    }
    .delete-btn:hover {
      background: var(--adm-danger, #ff4d4d);
      color: white;
    }
  </style>

  <script>
    // Set default dates
    document.addEventListener('DOMContentLoaded', () => {
      const today = new Date().toISOString().split('T')[0];
      document.getElementById('startDate').value = today;
      
      const nextMonth = new Date();
      nextMonth.setMonth(nextMonth.getMonth() + 1);
      document.getElementById('endDate').value = nextMonth.toISOString().split('T')[0];

      loadCoupons();
    });

    async function loadCoupons() {
      try {
        const res = await fetch('/api/admin/coupons');
        const coupons = await res.json();
        
        const list = document.getElementById('couponsList');
        if (coupons.length === 0) {
          list.innerHTML = '<div style="text-align: center; padding: 20px; color: var(--adm-muted);">Henüz tanımlı bir kupon bulunmuyor.</div>';
          return;
        }

        list.innerHTML = coupons.map(c => {
          const discountStr = c.type === 'percentage' ? '%' + c.value : c.value + ' ₺';
          const endD = new Date(c.endDate).toLocaleDateString('tr-TR');
          return '<div class="list-item">' +
            '<div class="list-item-info">' +
              '<strong>' + c.code + '</strong> (-' + discountStr + ')' +
              '<p>Min. Sepet: ' + c.minOrderAmount + ' ₺ | Bitiş: ' + endD + '</p>' +
            '</div>' +
            '<button onclick="deleteCoupon(\'' + c._id + '\')" class="delete-btn">SİL</button>' +
          '</div>';
        }).join('');
      } catch (err) {
        console.error(err);
      }
    }

    document.getElementById('couponForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const payload = {
        code: document.getElementById('code').value,
        type: document.getElementById('type').value,
        value: document.getElementById('value').value,
        minOrderAmount: document.getElementById('minOrderAmount').value,
        startDate: document.getElementById('startDate').value,
        endDate: document.getElementById('endDate').value
      };

      try {
        const res = await fetch('/api/admin/coupons', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
        
        const result = await res.json();
        if (result.success) {
          alert(result.message);
          document.getElementById('code').value = '';
          document.getElementById('value').value = '';
          document.getElementById('minOrderAmount').value = '0';
          loadCoupons();
        } else {
          alert(result.message);
        }
      } catch (err) {
        alert('Kupon eklenirken hata oluştu.');
      }
    });

    async function deleteCoupon(id) {
      if (!confirm('Bu kuponu silmek istediğinizden emin misiniz?')) return;
      try {
        const res = await fetch('/api/admin/coupons/' + id, {
          method: 'DELETE'
        });
        const result = await res.json();
        if (result.success) {
          loadCoupons();
        } else {
          alert(result.message);
        }
      } catch (err) {
        alert('Kupon silinirken hata oluştu.');
      }
    }
  </script>
  `
}) %>
