<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %> | Öz Spor & Outdoor</title>
<link rel="icon" type="image/png" href="/images/default-product.png">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root { --black: #0a0a0a; --white: #f5f5f0; --accent: #d4ff00; --gray-400: #999990; --gray-600: #555550; }
  body { font-family: 'Barlow', sans-serif; background: var(--black); color: var(--white); min-height: 100vh; display: flex; flex-direction: column; }

  /* Nav */
  .auth-nav { height: 64px; display: flex; align-items: center; justify-content: space-between; padding: 0 28px; border-bottom: 2px solid #1a1a1a; }
  .nav-logo { font-family: 'Bebas Neue', sans-serif; font-size: 22px; letter-spacing: 2px; color: var(--white); text-decoration: none; }
  .nav-logo span { color: var(--accent); }
  .nav-back { color: var(--gray-400); text-decoration: none; font-size: 13px; font-weight: 500; letter-spacing: 1px; transition: color .2s; }
  .nav-back:hover { color: var(--accent); }

  /* Container */
  .auth-wrapper { flex: 1; display: flex; align-items: center; justify-content: center; padding: 40px 20px; }
  .auth-card {
    width: 100%; max-width: 440px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    backdrop-filter: blur(20px);
    border-radius: 16px;
    padding: 40px 32px;
  }

  /* Header */
  .auth-header { text-align: center; margin-bottom: 28px; }
  .auth-header h2 { font-family: 'Bebas Neue', sans-serif; font-size: 32px; letter-spacing: 2px; color: var(--white); margin-bottom: 8px; }
  .auth-header p { font-size: 13px; color: var(--gray-400); line-height: 1.5; }
  .auth-header p strong { color: var(--white); }

  /* Form */
  .form-group { margin-bottom: 18px; }
  .form-group label { display: block; font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--gray-400); margin-bottom: 8px; }
  .form-group input {
    width: 100%; padding: 13px 16px; background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1); border-radius: 8px;
    color: var(--white); font-size: 14px; font-family: 'Barlow', sans-serif;
    transition: border-color .2s;
  }
  .form-group input:focus { outline: none; border-color: var(--accent); }
  .form-group input::placeholder { color: var(--gray-600); }

  .btn-auth {
    width: 100%; padding: 14px; margin-top: 8px;
    background: var(--accent); color: var(--black);
    font-size: 13px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase;
    border: none; border-radius: 8px; cursor: pointer;
    transition: background .2s, transform .1s;
  }
  .btn-auth:hover { background: #e3ff4d; }
  .btn-auth:active { transform: scale(0.98); }

  /* Messages */
  .msg-error { background: rgba(239,68,68,0.15); border: 1px solid rgba(239,68,68,0.3); color: #fca5a5; padding: 12px 16px; border-radius: 8px; font-size: 13px; margin-bottom: 20px; text-align: center; }

  @media (max-width: 480px) {
    .auth-card { padding: 32px 20px; }
  }
</style>
</head>
<body>

<nav class="auth-nav">
  <a href="/" class="nav-logo">Öz Spor <span>&</span> Outdoor</a>
  <a href="/products" class="nav-back">← Alışverişe Dön</a>
</nav>

<div class="auth-wrapper">
  <div class="auth-card">
    <div class="auth-header">
      <h2>Yeni Şifre Belirleyin</h2>
      <p><strong><%= email %></strong> hesabı için yeni şifrenizi girin.</p>
    </div>

    <% if (error) { %>
      <div class="msg-error"><%= error %></div>
    <% } %>

    <form method="POST" action="/account/reset-password">
      <input type="hidden" name="token" value="<%= token %>">
      
      <div class="form-group">
        <label>Yeni Şifre</label>
        <input type="password" name="password" placeholder="En az 6 karakter" required minlength="6">
      </div>
      
      <div class="form-group">
        <label>Yeni Şifre Tekrar</label>
        <input type="password" name="passwordConfirm" placeholder="Şifrenizi doğrulayın" required minlength="6">
      </div>
      
      <button type="submit" class="btn-auth">Şifreyi Güncelle</button>
    </form>
  </div>
</div>

</body>
</html>
